# Environment Variables
# Copy this file to .env.local and fill in your values

# Bundle Analyzer
# Set to "true" to enable bundle analysis during build
# ANALYZE=true

# Database (Supabase)
# DATABASE_URL="postgresql://..."
# DIRECT_URL="postgresql://..."

# Supabase
# NEXT_PUBLIC_SUPABASE_URL="https://..."
# NEXT_PUBLIC_SUPABASE_ANON_KEY="..."

# Xendit Payment Gateway
# XENDIT_SECRET_API_KEY="..."
# NEXT_PUBLIC_XENDIT_PUBLIC_API_KEY="..."
# XENDIT_WEBHOOK_TOKEN="..."

# Resend Email Service
# RESEND_API_KEY="re_..."
# RESEND_FROM_EMAIL="Talib by An Nisaa' <noreply@annisaasekolahku.com>"

# App Configuration
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Auth — OAuth callback origin (REQUIRED in production).
# Pinned alias used by lib/auth/callback-origin.ts to redirect post-login.
# Without this set in production, the OAuth callback throws — set it to the
# canonical alias (NOT a per-deployment Vercel URL).
# NEXT_PUBLIC_SITE_URL="https://app.example.com"

# Demo mode — E2E + local dev ONLY. NEVER set in production.
# When DEMO_MODE=true, /api/_demo/login becomes reachable and lib/auth/
# session.ts honours the school-erp-session cookie short-circuit.
# DEMO_MODE=true

# HMAC key for demo session cookie. Required when DEMO_MODE=true. Must be
# >= 32 chars (HMAC-SHA256 output is 32 bytes; secret >= output length per
# RFC 2104). Generate with: openssl rand -hex 32
# SESSION_COOKIE_SECRET="<32+ char random>"
