generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── TENANT (single for MVP, prepared for multi-tenant) ──────
model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())

  users                  User[]
  roles                  Role[]
  parents                Parent[]
  campuses               Campus[]
  employees              Employee[]
  holidays               Holiday[]
  orgConfig              OrgConfig?
  salaryDefs             SalaryComponentDef[]
  payrollRuns            PayrollRun[]
  academicYears          AcademicYear[]
  programs               Program[]
  classSections          ClassSection[]
  classTracks            ClassTrack[]
  students               Student[]
  admissions             Admission[]
  feeDefs                FeeComponentDef[]
  feeStructures          ProgramFeeStructure[]
  invoices               Invoice[]
  invoiceNumberSequences InvoiceNumberSequence[]
  emailLogs              EmailLog[]
  auditLogs              AuditLog[]
  semesters              Semester[]
  themes                 Theme[]
  subThemes              SubTheme[]
  weeks                  Week[]
  learningObjectives     LearningObjective[]
  achievementIndicators  AchievementIndicator[]
  assessmentEntries      AssessmentEntry[]
  terms                  Term[]
  reportCardEntries      ReportCardEntry[]
  studentMeasurements    StudentMeasurement[]
}

// ── USER ─────────────────────────────────────────────────────
// onDelete policy:
// - tenant   : Restrict — never delete a tenant with active users
// - employee : SetNull  — keep the user account if the staff record is removed
// - parent   : SetNull  — keep the user account if the parent record is removed
// - customRole: SetNull — fall back to the role string if the custom role is deleted
model User {
  id          String    @id @default(cuid())
  tenantId    String
  // email is unique PER TENANT, not globally — see @@unique below.
  // Two tenants may legitimately have admin@school.com without collision.
  email       String
  role        String
  employeeId  String?   @unique
  name        String?
  lastLoginAt DateTime?

  parentId     String?
  customRoleId String?
  status       String  @default("ACTIVE") // ACTIVE | INACTIVE

  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  parent     Parent?   @relation(fields: [parentId], references: [id], onDelete: SetNull)
  customRole Role?     @relation(fields: [customRoleId], references: [id], onDelete: SetNull)

  @@unique([tenantId, email])
  @@index([tenantId, status])
}

// ── ROLE (RBAC) ─────────────────────────────────────────────
model Role {
  id          String   @id @default(cuid())
  tenantId    String
  name        String // "Kepala Sekolah", "Admin Keuangan"
  code        String // "HEAD", "FINANCE_ADMIN"
  description String?
  isSystem    Boolean  @default(false)
  permissions String // JSON array: ["payroll.approve", "invoice.void"]
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  users  User[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

// ── CAMPUS ───────────────────────────────────────────────────
model Campus {
  id       String   @id @default(cuid())
  tenantId String
  name     String
  address  String?
  lat      Decimal? @db.Decimal(10, 8)
  lng      Decimal? @db.Decimal(11, 8)
  status   String   @default("ACTIVE") // ACTIVE | INACTIVE (binary soft-delete per CRUD Standard Category A)

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  employees     Employee[]
  classSections ClassSection[]
  classTracks   ClassTrack[]

  @@index([tenantId])
}

// ── ORG CONFIG ───────────────────────────────────────────────
// Restrict — tenant hard-delete is blocked while OrgConfig exists.
// Per-tenant working hours / payroll-period config is operationally
// load-bearing; admin must explicitly remove it before deleting the tenant.
model OrgConfig {
  id                    String  @id @default(cuid())
  tenantId              String  @unique
  workingDays           String
  workStartTime         String  @default("07:00")
  workEndTime           String  @default("16:00")
  gracePeriodMinutes    Int     @default(15)
  timezone              String  @default("Asia/Jakarta")
  payrollPeriodStartDay Int     @default(21)
  payrollPeriodEndDay   Int     @default(20)
  // F-14: When true, overtime (lembur) calculation follows UU 13/2003 §78(4)
  // tiered rates (1.5× first hour, 2× thereafter). Defaults false to preserve
  // the historical flat per-hour calculation until tenants explicitly opt in.
  lemburCompliant       Boolean @default(false)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
}

// ── HOLIDAY ──────────────────────────────────────────────────
model Holiday {
  id        String  @id @default(cuid())
  tenantId  String
  date      String
  name      String
  type      String
  isHalfDay Boolean @default(false)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([tenantId, date])
  @@index([tenantId])
}

// ── EMPLOYEE ─────────────────────────────────────────────────
model Employee {
  id            String   @id @default(cuid())
  tenantId      String
  kode          String
  nama          String
  formalName    String?
  email         String
  noHp          String?
  jabatan       String
  campusId      String
  hireDate      String
  status        String   @default("ACTIVE")
  bankAccountNo String?
  bankName      String?
  bpjsEnrolled  Boolean  @default(false)
  createdAt     DateTime @default(now())

  // Leave balances (reset annually)
  leaveBalanceAnnual Int @default(12)
  leaveBalanceSick   Int @default(14)

  tenant                   Tenant                @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  campus                   Campus                @relation(fields: [campusId], references: [id], onDelete: Restrict)
  user                     User?
  salaryValues             EmployeeSalaryValue[]
  attendanceRecords        AttendanceRecord[]
  payrollItems             PayrollItem[]
  leaveRequests            LeaveRequest[]
  teachingAssignments      TeachingAssignment[]
  recordedAssessments      AssessmentEntry[]     @relation("AssessmentRecordedBy")
  voidedAssessments        AssessmentEntry[]     @relation("AssessmentVoidedBy")
  sessionsAsTeacher        ClassSession[]        @relation("SessionTeacher")
  sessionsAsDefaultTeacher ClassSession[]        @relation("SessionDefaultTeacher")

  @@unique([tenantId, kode])
  @@index([tenantId, status])
  @@index([campusId])
}

// ── TEACHING ASSIGNMENT ──────────────────────────────────────
// Junction; cascade on both sides so removing an employee or class
// also clears the link.
model TeachingAssignment {
  id             String   @id @default(cuid())
  employeeId     String
  classSectionId String
  role           String   @default("HOMEROOM") // HOMEROOM | ASSISTANT
  createdAt      DateTime @default(now())

  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  classSection ClassSection @relation(fields: [classSectionId], references: [id], onDelete: Cascade)

  @@unique([employeeId, classSectionId])
  @@index([classSectionId])
}

// ── LEAVE ────────────────────────────────────────────────────
// Cascade — leave requests are tightly bound to the employee.
model LeaveRequest {
  id         String    @id @default(cuid())
  employeeId String
  leaveType  String // ANNUAL | SICK | PERMISSION | OTHER
  startDate  String // YYYY-MM-DD
  endDate    String // YYYY-MM-DD
  days       Int // Calculated duration
  reason     String
  status     String    @default("PENDING") // PENDING | APPROVED | REJECTED | CANCELLED
  reviewedBy String?
  reviewedAt DateTime?
  reviewNote String?
  createdAt  DateTime  @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, status, leaveType])
}

// ── SALARY COMPONENT ─────────────────────────────────────────
model SalaryComponentDef {
  id         String  @id @default(cuid())
  tenantId   String
  code       String
  label      String
  category   String
  calcType   String
  isProRated Boolean @default(false)
  isEnabled  Boolean @default(true)
  sortOrder  Int     @default(0)

  tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  values       EmployeeSalaryValue[]
  payrollLines PayrollItemLine[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, isEnabled])
}

// Cascade on Employee (values follow the employee); Restrict on
// componentDef (don't lose value rows just because someone tried to
// delete a salary component — disable it instead).
model EmployeeSalaryValue {
  id             String  @id @default(cuid())
  employeeId     String
  componentDefId String
  value          Decimal @default(0) @db.Decimal(15, 2)

  employee     Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  componentDef SalaryComponentDef @relation(fields: [componentDefId], references: [id], onDelete: Restrict)

  @@unique([employeeId, componentDefId])
  @@index([componentDefId])
}

// ── ATTENDANCE ───────────────────────────────────────────────
// Cascade — attendance is a leaf log row.
model AttendanceRecord {
  id               String    @id @default(cuid())
  employeeId       String
  date             String
  checkInTime      DateTime?
  checkOutTime     DateTime?
  checkInLat       Decimal?  @db.Decimal(10, 8)
  checkInLng       Decimal?  @db.Decimal(11, 8)
  checkOutLat      Decimal?  @db.Decimal(10, 8)
  checkOutLng      Decimal?  @db.Decimal(11, 8)
  status           String
  isManualOverride Boolean   @default(false)
  overrideReason   String?
  overriddenBy     String?
  overriddenAt     DateTime?
  isLocked         Boolean   @default(false)

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([employeeId, date])
  @@index([date])
  @@index([status])
}

// ── PAYROLL ──────────────────────────────────────────────────
// PayrollRun — Restrict on tenant (financial root).
model PayrollRun {
  id             String    @id @default(cuid())
  tenantId       String
  periodStart    String
  periodEnd      String
  actualWorkDays Int
  status         String    @default("DRAFT")
  createdBy      String
  approvedBy     String?
  approvedAt     DateTime?
  exportedAt     DateTime?
  slipsSentAt    DateTime?

  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  items  PayrollItem[]

  @@unique([tenantId, periodStart, periodEnd])
  @@index([tenantId, periodStart])
}

// PayrollItem — Cascade from PayrollRun (items belong to the run).
// Restrict on Employee — financial audit; never silently drop pay history.
model PayrollItem {
  id           String  @id @default(cuid())
  payrollRunId String
  employeeId   String
  grossAmount  Decimal @default(0) @db.Decimal(15, 2)
  deductions   Decimal @default(0) @db.Decimal(15, 2)
  netAmount    Decimal @default(0) @db.Decimal(15, 2)

  overtimeHours     Decimal @default(0) @db.Decimal(5, 2)
  outdoorDays       Int     @default(0)
  holidayWorkedDays Int     @default(0)
  dcDays            Int     @default(0)

  // Per-item idempotency for send-slips retry safety — true after a slip
  // email has been delivered so a retried run skips already-sent items.
  emailSent Boolean @default(false)

  payrollRun PayrollRun        @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee   Employee          @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  lines      PayrollItemLine[]

  @@index([payrollRunId, employeeId])
  @@index([employeeId])
}

// PayrollItemLine — Cascade from PayrollItem (lines follow the item).
// Restrict on componentDef so a deleted-by-mistake component doesn't
// silently zero out historical pay slips.
model PayrollItemLine {
  id               String  @id @default(cuid())
  payrollItemId    String
  componentDefId   String
  labelSnapshot    String
  categorySnapshot String
  calculatedAmount Decimal @default(0) @db.Decimal(15, 2)
  adjustmentAmount Decimal @default(0) @db.Decimal(15, 2)
  adjustmentNote   String?
  finalAmount      Decimal @default(0) @db.Decimal(15, 2)

  payrollItem  PayrollItem        @relation(fields: [payrollItemId], references: [id], onDelete: Cascade)
  componentDef SalaryComponentDef @relation(fields: [componentDefId], references: [id], onDelete: Restrict)

  @@index([payrollItemId])
  @@index([componentDefId])
}

// ── EMAIL LOG ────────────────────────────────────────────────
// Restrict — tenant hard-delete is blocked while audit rows exist.
// Email-send history is compliance/audit data; admin must explicitly
// archive or export before removing the tenant.
model EmailLog {
  id       String   @id @default(cuid())
  tenantId String
  to       String
  subject  String
  template String
  status   String   @default("PENDING")
  error    String?
  sentAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId])
}

// ══════════════════════════════════════════════════════════════
// PHASE 2: Academic Structure + Student Management
// ══════════════════════════════════════════════════════════════

// ── ACADEMIC YEAR ────────────────────────────────────────────
model AcademicYear {
  id        String @id @default(cuid())
  tenantId  String
  name      String // "2025/2026"
  startDate String // YYYY-MM-DD
  endDate   String // YYYY-MM-DD
  status    String @default("PLANNING") // PLANNING | ACTIVE | ARCHIVED

  tenant        Tenant                @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  classSections ClassSection[]
  feeStructures ProgramFeeStructure[]
  semesters     Semester[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

// ── PROGRAM ──────────────────────────────────────────────────
model Program {
  id          String  @id @default(cuid())
  tenantId    String
  code        String // "DCARE", "KB", "TKIT", "POPUP"
  name        String // "Day Care", "Kelompok Bermain", etc.
  description String?
  type        String // SEMESTER | YEAR_ROUND | SESSION
  ageMin      Int? // Minimum age in months
  ageMax      Int? // Maximum age in months
  status      String  @default("ACTIVE") // ACTIVE | INACTIVE (binary soft-delete per CRUD Standard Category A)

  tenant              Tenant                @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  classSections       ClassSection[]
  classTracks         ClassTrack[]
  admissions          Admission[]
  feeStructures       ProgramFeeStructure[]
  assessmentTemplates AssessmentTemplate[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

// ── CLASS TRACK ──────────────────────────────────────────────
// Stable multi-year class identity (e.g. "TKIT A" persists across
// academic years). ClassSection is the per-year instance of a track.
// All FKs Restrict — a track is configuration, not a leaf row; never
// auto-drop it when a tenant/campus/program is removed.
model ClassTrack {
  id        String @id @default(cuid())
  tenantId  String
  campusId  String
  programId String
  name      String // "TKIT A", "KB Aster"
  status    String @default("ACTIVE") // ACTIVE | INACTIVE (binary soft-delete per CRUD Standard Category A)

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  campus   Campus         @relation(fields: [campusId], references: [id], onDelete: Restrict)
  program  Program        @relation(fields: [programId], references: [id], onDelete: Restrict)
  sections ClassSection[]

  @@unique([tenantId, campusId, programId, name])
  @@index([tenantId, status])
}

// ── CLASS SECTION ────────────────────────────────────────────
model ClassSection {
  id             String   @id @default(cuid())
  tenantId       String
  classTrackId   String
  programId      String
  academicYearId String
  name           String // "TKIT A", "KB Aster", "D'Care Metland"
  ageGroup       AgeGroup // A (4-5 yo) | B (5-6 yo) — was derived from name; column added 2026-05-20
  capacity       Int      @default(20)
  campusId       String
  slotTemplate   String   @default("FULL_DAY") // FULL_DAY | MORNING_AND_AFTERNOON
  status         String   @default("ACTIVE") // ACTIVE | INACTIVE

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  classTrack          ClassTrack           @relation(fields: [classTrackId], references: [id], onDelete: Restrict)
  program             Program              @relation(fields: [programId], references: [id], onDelete: Restrict)
  academicYear        AcademicYear         @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  campus              Campus               @relation(fields: [campusId], references: [id], onDelete: Restrict)
  enrollments         StudentEnrollment[]
  teachingAssignments TeachingAssignment[]
  studentAttendances  StudentAttendance[]
  sessions            ClassSession[]

  @@unique([tenantId, academicYearId, name])
  @@index([tenantId])
}

// ── CLASS SESSION ────────────────────────────────────────────
// A daily class meeting. Tenancy is indirect through ClassSection
// (no tenantId column). Cascade from ClassSection (sessions follow
// the class); Restrict on Semester (the anchoring date range is
// configuration); SetNull on both teacher FKs so removing an
// employee leaves the historical session row intact.
// @rls-indirect: via ClassSection
model ClassSession {
  id               String   @id @default(cuid())
  classSectionId   String
  semesterId       String // anchors the session's date range to a Semester
  date             String // YYYY-MM-DD (Jakarta-tz calendar date)
  slot             String   @default("FULL_DAY") // FULL_DAY | MORNING | AFTERNOON
  teacherId        String? // the EFFECTIVE teacher (may be a substitute)
  defaultTeacherId String? // snapshot of the class homeroom at session creation; preserved across substitute swaps for audit
  substituteReason String?
  isBackfilled     Boolean  @default(false) // true if the session row was created or edited for a past date
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  classSection   ClassSection        @relation(fields: [classSectionId], references: [id], onDelete: Cascade)
  semester       Semester            @relation(fields: [semesterId], references: [id], onDelete: Restrict)
  teacher        Employee?           @relation("SessionTeacher", fields: [teacherId], references: [id], onDelete: SetNull)
  defaultTeacher Employee?           @relation("SessionDefaultTeacher", fields: [defaultTeacherId], references: [id], onDelete: SetNull)
  attendances    StudentAttendance[]

  @@unique([classSectionId, date, slot])
  @@index([teacherId, date])
  @@index([date])
  @@index([semesterId])
}

// ── STUDENT ──────────────────────────────────────────────────
model Student {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  nickname    String?
  dateOfBirth String? // YYYY-MM-DD
  gender      String? // L | P
  address     String?
  photoUrl    String?
  notes       String?
  metadata    String? // JSON for custom fields (hobby, blood type, allergies, etc.)
  status      String   @default("ACTIVE") // ACTIVE | INACTIVE | GRADUATED | WITHDRAWN
  createdAt   DateTime @default(now())

  // Government compliance fields
  nis        String? // Nomor Induk Siswa (school-assigned)
  nisn       String? // Nomor Induk Siswa Nasional
  birthPlace String? // Tempat lahir
  nik        String? // NIK anak (16 digits)
  kkNumber   String? // No. Kartu Keluarga
  livingWith String? // ORANG_TUA | WALI | LAINNYA

  // Lifecycle tracking
  withdrawalReason String?
  withdrawalDate   String? // YYYY-MM-DD
  graduationDate   String? // YYYY-MM-DD

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  guardians           StudentGuardian[]
  enrollments         StudentEnrollment[]
  admission           Admission?
  invoices            Invoice[]
  studentAttendances  StudentAttendance[]
  assessments         StudentAssessment[]
  assessmentEntries   AssessmentEntry[]
  reportCardEntries   ReportCardEntry[]
  studentMeasurements StudentMeasurement[]

  @@index([tenantId, status])
  @@index([nis], map: "Student_nis_idx")
  @@index([nisn], map: "Student_nisn_idx")
}

// ── PARENT (the actual person — contact info lives here) ────
model Parent {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  email     String?
  phone     String?
  whatsapp  String?
  address   String?
  status    String   @default("ACTIVE") // ACTIVE | INACTIVE
  createdAt DateTime @default(now())

  // Government compliance fields
  nik             String? // NIK orang tua (16 digits)
  education       String? // SMA | D1-D3 | S1 | S2 | S3 | Profesi
  occupation      String? // Karyawan Swasta | ASN | Guru | Wiraswasta | Ibu Rumah Tangga
  employer        String? // Nama perusahaan
  employerAddress String? // Alamat kantor
  employerCity    String? // Kota/Kab
  incomeRange     String? // "< 1jt" | "1-2jt" | "3-5jt" | "5-10jt" | "7-10jt" | "> 10jt"
  childrenTotal   Int? // Total anak (including non-students at this school)

  // Document scans (auth-proxy storage tokens)
  ktpUrl String? // KTP scan
  kkUrl  String? // Family card (KK) scan

  tenant             Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  guardians          StudentGuardian[]
  invoices           Invoice[]
  users              User[]
  detectedAdmissions Admission[]       @relation("AdmissionDetectedParent")

  @@unique([tenantId, email])
  @@index([tenantId, status])
}

// ── STUDENT ↔ PARENT JUNCTION (relationship + billing) ──────
// Junction; cascade so removing a student or parent clears the link.
model StudentGuardian {
  id           String  @id @default(cuid())
  studentId    String
  parentId     String
  relationship String // AYAH | IBU | WALI | OTHER
  isPrimary    Boolean @default(false) // Primary billing contact for this student
  childOrder   Int? // Anak ke- (this student's position in the parent's family)
  status       String  @default("ACTIVE") // ACTIVE | INACTIVE (soft delete)

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parent  Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@unique([studentId, parentId])
  @@index([parentId])
  @@index([studentId, status])
}

// ── STUDENT ENROLLMENT ───────────────────────────────────────
// Cascade on Student (enrollments follow the child if hard-deleted);
// Restrict on ClassSection so the class can't disappear out from under
// active enrollments.
model StudentEnrollment {
  id             String   @id @default(cuid())
  studentId      String
  classSectionId String
  enrollDate     String // YYYY-MM-DD
  status         String   @default("ACTIVE") // ACTIVE | GRADUATED | WITHDRAWN
  notes          String?
  createdAt      DateTime @default(now())

  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classSection ClassSection @relation(fields: [classSectionId], references: [id], onDelete: Restrict)

  @@unique([studentId, classSectionId])
  @@index([classSectionId, status])
  @@index([studentId, status])
}

// ── ADMISSION ────────────────────────────────────────────────
// Tenant: Restrict (admissions are CRM funnel records — never auto-drop).
// Optional FKs (program, student) default to SetNull if the linked entity
// is removed; we make this explicit.
model Admission {
  id                 String   @id @default(cuid())
  tenantId           String
  childName          String
  childAge           String? // e.g., "4 tahun"
  childGender        String? // L | P
  dateOfBirth        String? // YYYY-MM-DD
  parentName         String
  parentPhone        String?
  parentEmail        String?
  parentWhatsapp     String?
  parentEducation    String? // SMA | D1-D3 | S1 | S2 | S3
  parentOccupation   String? // Karyawan Swasta | ASN | Guru | Wiraswasta | BUMN | Ibu Rumah Tangga | Lainnya
  parentIncome       String? // < Rp 1 Juta | Rp 1-2 Juta | Rp 3-5 Juta | Rp 5-10 Juta | > Rp 10 Juta
  parentRelationship String? // AYAH | IBU | WALI | OTHER
  programId          String? // Program of interest
  campusPreference   String? // Campus ID
  source             String   @default("WALK_IN") // WHATSAPP | WALK_IN | WEBSITE | REFERRAL | OTHER
  status             String   @default("INQUIRY") // INQUIRY | VISIT_SCHEDULED | VISITED | ADMITTED | CANCELLED — "converted" encoded by studentId IS NOT NULL (cycle 2026-05-12 dropped REGISTERED)
  notes              String?
  followUpDate       String? // YYYY-MM-DD
  studentId          String?  @unique // Linked when converted to student
  detectedParentId   String? // Sibling-detect match (cycle 1.2) — nullable FK to Parent
  createdAt          DateTime @default(now())

  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  program        Program? @relation(fields: [programId], references: [id], onDelete: SetNull)
  student        Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)
  detectedParent Parent?  @relation("AdmissionDetectedParent", fields: [detectedParentId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([tenantId, detectedParentId])
}

// ══════════════════════════════════════════════════════════════
// PHASE 3: Fee Structure + Invoicing
// ══════════════════════════════════════════════════════════════

// ── FEE COMPONENT DEFINITION ─────────────────────────────────
model FeeComponentDef {
  id          String  @id @default(cuid())
  tenantId    String
  code        String // e.g., "spp", "uang_pangkal", "seragam"
  label       String // e.g., "SPP Bulanan", "Uang Pangkal"
  category    String // TUITION | REGISTRATION | ACTIVITY | MATERIAL | OTHER
  isRecurring Boolean @default(true) // monthly vs one-time
  isEnabled   Boolean @default(true)
  sortOrder   Int     @default(0)
  status      String  @default("ACTIVE") // ACTIVE | INACTIVE (soft delete per CRUD Standard)

  tenant        Tenant                @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  feeStructures ProgramFeeStructure[]
  invoiceLines  InvoiceLine[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
}

// ── PROGRAM FEE STRUCTURE ────────────────────────────────────
// All FKs Restrict — fee structure is configuration, not a leaf row.
model ProgramFeeStructure {
  id             String  @id @default(cuid())
  tenantId       String
  programId      String
  academicYearId String
  feeComponentId String
  amount         Decimal @default(0) @db.Decimal(15, 2)
  notes          String?
  status         String  @default("ACTIVE") // ACTIVE | INACTIVE

  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  program      Program         @relation(fields: [programId], references: [id], onDelete: Restrict)
  academicYear AcademicYear    @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  feeComponent FeeComponentDef @relation(fields: [feeComponentId], references: [id], onDelete: Restrict)

  @@unique([programId, academicYearId, feeComponentId])
  @@index([tenantId, status])
}

// ── INVOICE NUMBER SEQUENCE ──────────────────────────────────
// Per-tenant, per-year allocator backing nextInvoiceNumber().
// The allocator issues a single atomic INSERT … ON CONFLICT DO UPDATE …
// RETURNING "lastNumber" inside the invoice-creation transaction, so a
// rollback returns the sequence number too. Year prefix is computed in
// Asia/Jakarta (WIB) to avoid producing INV-2025 invoices on Jan 1 mornings.
model InvoiceNumberSequence {
  tenantId   String
  year       Int
  lastNumber Int    @default(0)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@id([tenantId, year])
}

// ── INVOICE ──────────────────────────────────────────────────
// Restrict on tenant + student — financial records, never silently drop.
// Parent is optional billing contact: SetNull on parent removal.
model Invoice {
  id               String    @id @default(cuid())
  tenantId         String
  studentId        String
  invoiceNumber    String // Auto-generated: INV-2026-0001
  periodLabel      String // "April 2026" or "Semester 1 2025/2026"
  dueDate          String // YYYY-MM-DD
  totalDue         Decimal   @default(0) @db.Decimal(15, 2)
  totalPaid        Decimal   @default(0) @db.Decimal(15, 2)
  status           String    @default("DRAFT") // DRAFT | SENT | PARTIALLY_PAID | PAID | OVERDUE | CANCELLED | PENDING_PAYMENT_LINK
  createdBy        String
  sentAt           DateTime?
  paidAt           DateTime?
  parentId         String? // Billing contact (Parent)
  xenditSessionId  String? // Xendit checkout session ID
  xenditPaymentUrl String? // Xendit hosted checkout URL
  paymentLinkError String? // Diagnostic msg when Xendit session creation failed (status=PENDING_PAYMENT_LINK)
  createdAt        DateTime  @default(now())

  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  student  Student       @relation(fields: [studentId], references: [id], onDelete: Restrict)
  parent   Parent?       @relation(fields: [parentId], references: [id], onDelete: SetNull)
  lines    InvoiceLine[]
  payments Payment[]

  @@unique([tenantId, invoiceNumber])
  @@index([studentId, status])
  @@index([tenantId, status, dueDate])
  @@index([dueDate])
  @@index([status])
  @@index([parentId])
}

// ── INVOICE LINE ─────────────────────────────────────────────
// Cascade from Invoice (lines follow the invoice). Restrict on
// FeeComponentDef — historical lines must keep their reference.
model InvoiceLine {
  id               String  @id @default(cuid())
  invoiceId        String
  feeComponentId   String
  labelSnapshot    String
  amount           Decimal @default(0) @db.Decimal(15, 2)
  adjustmentAmount Decimal @default(0) @db.Decimal(15, 2)
  adjustmentNote   String?
  finalAmount      Decimal @default(0) @db.Decimal(15, 2)

  invoice      Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  feeComponent FeeComponentDef @relation(fields: [feeComponentId], references: [id], onDelete: Restrict)

  @@index([invoiceId])
  @@index([feeComponentId])
}

// ── PAYMENT ──────────────────────────────────────────────────
// Restrict — payments are an audit trail; never cascade-delete.
model Payment {
  id              String   @id @default(cuid())
  invoiceId       String
  amount          Decimal  @db.Decimal(15, 2)
  method          String   @default("CASH") // CASH | BANK_TRANSFER | XENDIT | OTHER
  reference       String? // Bank transfer ref
  notes           String?
  status          String   @default("RECORDED") // RECORDED | APPROVED | REVERSED
  createdBy       String? // User ID who recorded
  xenditPaymentId String?  @unique // Idempotency key for Xendit webhooks
  paidAt          DateTime @default(now())
  createdAt       DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  @@index([invoiceId, status])
  @@index([createdAt])
}

// ══════════════════════════════════════════════════════════════
// PHASE 6: Student Attendance
// ══════════════════════════════════════════════════════════════

// Cascade on Student (logs follow the child); Restrict on ClassSection
// so a class can't be deleted out from under outstanding attendance.
model StudentAttendance {
  id                 String    @id @default(cuid())
  studentId          String
  classSectionId     String
  sessionId          String? // ClassSession this attendance belongs to (primary linkage going forward)
  date               String // YYYY-MM-DD
  status             String    @default("PRESENT") // PRESENT | ABSENT | SICK | PERMISSION
  checkInTime        DateTime?
  checkOutTime       DateTime?
  checkedInBy        String? // Employee ID who marked attendance
  pickedUpByRelation String? // PARENT | GUARDIAN | GRANDPARENT | SIBLING | DRIVER | HOUSEHOLD_HELPER | OTHER
  pickedUpByName     String? // free text; required app-side when pickedUpByRelation = OTHER
  notes              String?
  isVoided           Boolean   @default(false) // soft-delete; voided = admin marked incorrect
  createdAt          DateTime  @default(now())

  student      Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classSection ClassSection  @relation(fields: [classSectionId], references: [id], onDelete: Restrict)
  session      ClassSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  /// NOTE: @@unique([studentId, sessionId]) does NOT constrain rows where
  /// sessionId IS NULL (Postgres treats NULLs as distinct). A raw partial
  /// unique index — "StudentAttendance_studentId_date_legacy_key" ON
  /// (studentId, date) WHERE sessionId IS NULL — lives in migration
  /// 20260515000000_academic_hierarchy_refactor to keep the legacy
  /// session-agnostic marking path atomic. Prisma can't express partial
  /// indexes, so it exists in SQL only. Dropped by Task 7's follow-up cycle
  /// once every attendance row carries a non-NULL sessionId.

  @@unique([studentId, sessionId])
  @@index([studentId, date])
  @@index([classSectionId, date])
  @@index([date])
  @@index([isVoided])
}

// ══════════════════════════════════════════════════════════════
// PHASE 8: Student Journal (Buku Penghubung)
// ══════════════════════════════════════════════════════════════

enum JournalStatus {
  ACTIVE
  INACTIVE
}

model StudentJournalTemplate {
  id             String        @id @default(cuid())
  tenantId       String        @unique
  academicYearId String?
  status         JournalStatus @default(ACTIVE)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  categories StudentJournalCategory[]
}

// Cascade — categories belong to a single template lifecycle.
model StudentJournalCategory {
  id         String        @id @default(cuid())
  templateId String
  scope      String // SCHOOL | HOME
  name       String
  order      Int           @default(0)
  status     JournalStatus @default(ACTIVE)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  template   StudentJournalTemplate    @relation(fields: [templateId], references: [id], onDelete: Cascade)
  indicators StudentJournalIndicator[]

  @@index([templateId, scope, status])
}

// Cascade — indicators belong to a category.
model StudentJournalIndicator {
  id         String        @id @default(cuid())
  categoryId String
  label      String
  order      Int           @default(0)
  status     JournalStatus @default(ACTIVE)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  category StudentJournalCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  entries  StudentJournalEntry[]

  @@index([categoryId, status])
}

// Cascade — entries are audit-log rows tied to the indicator.
model StudentJournalEntry {
  id               String   @id @default(cuid())
  tenantId         String
  studentId        String
  classSectionId   String?
  indicatorId      String
  date             String
  scope            String
  checked          Boolean
  recordedByUserId String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  indicator StudentJournalIndicator @relation(fields: [indicatorId], references: [id], onDelete: Cascade)

  @@unique([studentId, indicatorId, date, scope])
  @@index([tenantId, classSectionId, date])
  @@index([tenantId, studentId, date])
}

model StudentJournalNote {
  id           String        @id @default(cuid())
  tenantId     String
  studentId    String
  date         String
  authorUserId String
  authorRole   String
  body         String        @db.Text
  status       JournalStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([tenantId, studentId, date])
}

model StudentJournalAudit {
  id              String   @id @default(cuid())
  tenantId        String
  entityType      String // ENTRY | NOTE
  entityId        String
  action          String // CREATE | UPDATE | DELETE
  beforeJson      Json?
  afterJson       Json?
  changedByUserId String
  changedAt       DateTime @default(now())

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, changedAt])
}

// ══════════════════════════════════════════════════════════════
// PHASE 7: Report Cards / Assessments
// ══════════════════════════════════════════════════════════════

// Restrict on Program — templates are configuration; don't drop with the program.
model AssessmentTemplate {
  id        String  @id @default(cuid())
  tenantId  String
  programId String
  name      String // "Laporan Perkembangan Semester 1"
  type      String  @default("SEMESTER") // SEMESTER | QUARTERLY | MONTHLY
  isActive  Boolean @default(true)

  program     Program              @relation(fields: [programId], references: [id], onDelete: Restrict)
  categories  AssessmentCategory[]
  assessments StudentAssessment[]

  @@unique([tenantId, programId, name, type])
  @@index([tenantId])
}

// Cascade — categories belong to a template.
model AssessmentCategory {
  id         String @id @default(cuid())
  templateId String
  name       String // "Perkembangan Motorik Halus"
  sortOrder  Int    @default(0)

  template   AssessmentTemplate    @relation(fields: [templateId], references: [id], onDelete: Cascade)
  indicators AssessmentIndicator[]
}

// Cascade — indicators belong to a category.
model AssessmentIndicator {
  id          String @id @default(cuid())
  categoryId  String
  description String // "Dapat memegang pensil dengan benar"
  sortOrder   Int    @default(0)

  category AssessmentCategory       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  scores   StudentAssessmentScore[]
}

// Restrict on both — academic record; never silently lose a student's
// rapor by deleting the parent template or student.
model StudentAssessment {
  id          String    @id @default(cuid())
  studentId   String
  templateId  String
  period      String // "Semester 1 2025/2026"
  status      String    @default("DRAFT") // DRAFT | PUBLISHED
  createdBy   String
  publishedAt DateTime?
  createdAt   DateTime  @default(now())

  student  Student                  @relation(fields: [studentId], references: [id], onDelete: Restrict)
  template AssessmentTemplate       @relation(fields: [templateId], references: [id], onDelete: Restrict)
  scores   StudentAssessmentScore[]

  @@unique([studentId, templateId, period])
}

// Cascade — scores belong to an assessment + indicator pair.
model StudentAssessmentScore {
  id           String  @id @default(cuid())
  assessmentId String
  indicatorId  String
  score        String? // BB | MB | BSH | BSB
  notes        String?

  assessment StudentAssessment   @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  indicator  AssessmentIndicator @relation(fields: [indicatorId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, indicatorId])
}

// ── AUDIT LOG ────────────────────────────────────────────────
// Append-only history of mutating actions on sensitive entities.
// Every row is keyed to a tenant + actor; `before` and `after` capture
// the JSON shape pre/post mutation so reviewers can reconstruct intent.
// No update/delete API — rows live forever (or until a retention job).
// Retention: a periodic cleanup job is a follow-up — not in scope yet.
model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  actorId   String // session.id (User.id) of the actor; not a FK so deleted users keep history
  entity    String // "Employee" | "EmployeeSalaryValue" | "PayrollRun" | etc.
  entityId  String
  action    String // "create" | "update" | "delete" | domain-specific verb
  before    Json?
  after     Json?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId, entity, entityId])
  @@index([tenantId, createdAt])
  @@index([tenantId, actorId, createdAt])
}

// ── WEBHOOK EVENT (audit + dedup) ────────────────────────────
// Captures every inbound webhook delivery from third-party providers.
// **Intentionally global (no tenantId)** — webhooks arrive at a
// tenant-agnostic public endpoint; tenant is resolved post-hoc via the
// invoice join. Trusting payload-supplied tenantId before auth would be
// an injection vector.
// `eventId` is UNIQUE — incoming webhook with the same id is treated as a
// duplicate at the DB layer (P2002 → 200 noop in the route handler).
// `payload` keeps the full JSON for replay/audit. **Treat as PII** — never
// log or echo in error responses; never expose via a user-facing API.
// ERROR rows retained for admin audit; provider retries deduplicate via
// eventId @unique (Phase 1 short-circuits on P2002 with 200 noop).
// Retention: 90-day cleanup job is a follow-up (filed in Ship Notes).
model WebhookEvent {
  id           String    @id @default(cuid())
  provider     String // "xendit"
  eventId      String    @unique
  eventType    String
  payload      Json
  status       String    @default("RECEIVED") // RECEIVED | PROCESSED | ERROR | IGNORED
  invoiceId    String?
  errorMessage String?
  createdAt    DateTime  @default(now())
  processedAt  DateTime?

  @@index([provider, createdAt])
  @@index([invoiceId])
}

// ── CURRICULUM ───────────────────────────────────────────────
// Pack 1 / Cycle 1: structured Curriculum schema replacing 60+ weekly xlsx.
// All tenant-scoped, soft-delete via `status` (Category A per .claude/standards/crud.md).
// Field names English; user-facing display copy stays Indonesian.
// AchievementLevel enum is declared here even though its first use is C4
// (AssessmentEntry) — declaring now prevents enum collision later.

enum CurriculumElement {
  RELIGIOUS_MORAL // Nilai Agama dan Budi Pekerti
  IDENTITY // Jati Diri
  STEAM // STEAM / Literasi
  MOTOR_SKILLS // Motorik
  ART // Seni
}

enum AgeGroup {
  A // 4-5 years (TK A)
  B // 5-6 years (TK B)
}

enum AchievementLevel {
  CONSISTENT // Konsisten — first use C4 (AssessmentEntry); declared here to lock the enum name
  EMERGING // Berkembang / Belum konsisten
  NEEDS_REINFORCEMENT // Perlu penguatan
}

model Semester {
  id             String   @id @default(cuid())
  tenantId       String
  academicYearId String
  number         Int // 1 or 2
  startDate      DateTime // UTC midnight of the Jakarta-tz day
  endDate        DateTime // UTC midnight of the Jakarta-tz day
  status         String   @default("ACTIVE") // ACTIVE | INACTIVE
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  academicYear  AcademicYear        @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  themes        Theme[]
  objectives    LearningObjective[]
  classSessions ClassSession[]
  terms         Term[]

  @@unique([tenantId, academicYearId, number])
  @@index([tenantId])
  @@index([tenantId, academicYearId])
}

model Theme {
  id         String   @id @default(cuid())
  tenantId   String
  semesterId String
  name       String // Indonesian, e.g. "Saya Anak Sehat"
  order      Int
  status     String   @default("ACTIVE") // ACTIVE | INACTIVE
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant    Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  semester  Semester             @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  subThemes SubTheme[]
  links     IndicatorThemeLink[]

  @@unique([tenantId, semesterId, name])
  @@index([tenantId])
  @@index([tenantId, semesterId])
}

model SubTheme {
  id        String   @id @default(cuid())
  tenantId  String
  themeId   String
  name      String // Indonesian
  order     Int
  status    String   @default("ACTIVE") // ACTIVE | INACTIVE
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  theme  Theme  @relation(fields: [themeId], references: [id], onDelete: Cascade)
  weeks  Week[]

  @@unique([tenantId, themeId, name])
  @@index([tenantId])
  @@index([tenantId, themeId])
}

model Week {
  id         String   @id @default(cuid())
  tenantId   String
  subThemeId String
  number     Int // 1..N within semester (validated app-side, not enforced by unique constraint alone)
  startDate  DateTime // Monday (UTC midnight of Jakarta-tz day)
  endDate    DateTime // Friday (UTC midnight of Jakarta-tz day)
  status     String   @default("ACTIVE") // ACTIVE | INACTIVE
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  subTheme SubTheme          @relation(fields: [subThemeId], references: [id], onDelete: Cascade)
  entries  AssessmentEntry[]

  @@unique([tenantId, subThemeId, number])
  @@index([tenantId])
  @@index([tenantId, subThemeId])
  @@index([tenantId, startDate, endDate])
}

model LearningObjective {
  id             String            @id @default(cuid())
  tenantId       String
  semesterId     String
  ageGroup       AgeGroup
  element        CurriculumElement
  number         Int // 1..N within element+ageGroup
  competencyText String // CAPAIAN PERKEMBANGAN DIRI
  content        String // Tujuan Pembelajaran narrative
  status         String            @default("ACTIVE") // ACTIVE | INACTIVE
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  tenant     Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  semester   Semester               @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  indicators AchievementIndicator[]

  @@unique([tenantId, semesterId, ageGroup, element, number])
  @@index([tenantId])
  @@index([tenantId, semesterId])
}

model AchievementIndicator {
  id          String   @id @default(cuid())
  tenantId    String
  objectiveId String
  content     String // IKTP text, Indonesian
  order       Int
  status      String   @default("ACTIVE") // ACTIVE | INACTIVE
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant     Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  objective  LearningObjective    @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  themeLinks IndicatorThemeLink[]
  entries    AssessmentEntry[]

  @@index([tenantId])
  @@index([tenantId, objectiveId])
}

// Junction: which Themes a given AchievementIndicator is exercised under.
// No tenantId; tenant boundary enforced by the parent indicator + theme rows.
// Service-role-only writes; no RLS policy required (no tenantId column for the
// rls-coverage script to flag).
model IndicatorThemeLink {
  indicatorId String
  themeId     String
  createdAt   DateTime @default(now())

  indicator AchievementIndicator @relation(fields: [indicatorId], references: [id], onDelete: Cascade)
  theme     Theme                @relation(fields: [themeId], references: [id], onDelete: Cascade)

  @@id([indicatorId, themeId])
  @@index([themeId])
}

// ── ASSESSMENT ENTRY ─────────────────────────────────────────
// Pack 1 / Cycle 4: per-student per-indicator assessment record.
// Replaces ad-hoc usage of the legacy AssessmentTemplate scoring
// (BB/MB/BSH/BSB) with the locked 3-level AchievementLevel enum.
// `source` discriminates HOMEROOM (walas weekly) vs CENTER (sentra daily, C5).

enum AssessmentSource {
  HOMEROOM // Walas Pekanan
  CENTER // Sentra Harian
}

enum LearningCenter {
  WORSHIP // Sentra Ibadah
  NATURAL_MATERIALS // Sentra Bahan Alam
  ART // Sentra Seni
  COOKING // Sentra Memasak
  ROLE_PLAY // Sentra Main Peran
  BLOCKS // Sentra Balok
  PREPARATION // Sentra Persiapan
  AREA // AREA
}

model AssessmentEntry {
  id           String           @id @default(cuid())
  tenantId     String
  studentId    String
  indicatorId  String
  date         DateTime         @db.Date // Jakarta-tz date (UTC midnight of the Jakarta day)
  weekId       String // denormalized for fast roll-up; resolved server-side via getCurrentWeek
  source       AssessmentSource
  center       LearningCenter? // required iff source = CENTER (validated app-side)
  activity     String? // free-text kegiatan (used for sentra context, optional for HOMEROOM)
  level        AchievementLevel
  note         String?
  recordedById String
  recordedAt   DateTime         @default(now())

  // C7a: soft-void for admin Category-C override + audit trail.
  // Active row = voidedAt IS NULL. Voided rows are retained as audit history;
  // raport / parent-perkembangan rollups filter on voidedAt IS NULL.
  voidedAt   DateTime?
  voidedById String?
  voidReason String?

  tenant     Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  student    Student              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  indicator  AchievementIndicator @relation(fields: [indicatorId], references: [id], onDelete: Restrict)
  week       Week                 @relation(fields: [weekId], references: [id], onDelete: Restrict)
  recordedBy Employee             @relation("AssessmentRecordedBy", fields: [recordedById], references: [id], onDelete: Restrict)
  voidedBy   Employee?            @relation("AssessmentVoidedBy", fields: [voidedById], references: [id], onDelete: Restrict)

  /// NOTE: C7a adds soft-void columns (voidedAt/voidedById/voidReason) but leaves the
  /// existing @@unique([tenantId, studentId, indicatorId, date, source]) in place — so
  /// the C4/C5 walas+sentra upsert callers keep their Prisma upsert key. C7b will swap
  /// this to a partial unique "WHERE voidedAt IS NULL" together with refactoring those
  /// callers to raw-SQL ON CONFLICT, so schema + consumers ship in one PR. Until C7b
  /// lands, override semantics are single-row in-place: a voided row contains the
  /// LAST authoritative level + a voidedAt marker; raport rollups filter on voidedAt IS NULL.

  @@unique([tenantId, studentId, indicatorId, date, source])
  @@index([tenantId, weekId, studentId])
  @@index([tenantId, studentId, date])
  @@index([voidedAt])
}

// ── RAPORT (C8 — Admin Raport MVP) ───────────────────────────
// Per-student triwulan report card. This cycle ships the admin-driven slice:
// kisi-kisi narrative templates + teacher/walas authoring + parent sign are
// later phases. Sign + parent columns exist now (nullable) but stay unwired.

/// Narrative section of a raport. 5 bucketed (3-level narratives) + 3 closing
/// (single-content). MVP auto-suggests levels for the bucketed sections from
/// AssessmentEntry; narratives are admin-typed free-text until kisi-kisi lands.
enum ReportSection {
  // bucketed (level-bearing):
  INTRODUCTION
  RELIGIOUS_MORAL
  IDENTITY
  STEAM
  PERFORMANCE_SHOWCASE // Unjuk Kerja — pools MOTOR_SKILLS + ART penilaian

  // single-content (no level):
  CLOSING // Penutup
  FOLLOW_UP_PLAN // Rencana Tindak Lanjut
  HOME_ACTIVITIES // Kegiatan Disarankan di Rumah
}

/// Triwulan window. 2 per Semester (4/year). Defines the penilaian +
/// attendance aggregation window for raport drafting.
model Term {
  id          String    @id @default(cuid())
  tenantId    String
  semesterId  String
  number      Int // 1 or 2 within the semester
  startDate   DateTime // UTC midnight of the Jakarta-tz day
  endDate     DateTime // UTC midnight of the Jakarta-tz day
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  tenant            Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  semester          Semester             @relation(fields: [semesterId], references: [id], onDelete: Restrict)
  reportCardEntries ReportCardEntry[]
  measurements      StudentMeasurement[]

  @@unique([tenantId, semesterId, number])
  @@index([tenantId])
  @@index([tenantId, semesterId])
}

/// One report card per student per term. Section levels + narratives are JSON
/// (5 fixed sections, atomic per-entry write — master design rationale).
model ReportCardEntry {
  id                String  @id @default(cuid())
  tenantId          String
  studentId         String
  termId            String
  homeroomTeacherId String? // walas (nullable; admin-set in MVP, no FK)

  // { RELIGIOUS_MORAL: "CONSISTENT", IDENTITY: "EMERGING", ... } — keyed by
  // ReportSection, value AchievementLevel. Closing sections omitted (no level).
  sectionLevels     Json
  // { INTRODUCTION: "...", RELIGIOUS_MORAL: "...", CLOSING: "...", ... } —
  // keyed by ReportSection, value markdown narrative (Indonesian).
  sectionNarratives Json

  // Attendance (auto-pulled from StudentAttendance over the term window; admin may override)
  permittedAbsenceDays Int @default(0) // izin (PERMISSION)
  sickDays             Int @default(0) // sakit (SICK)
  unexcusedAbsenceDays Int @default(0) // alpa (ABSENT)
  totalSchoolDays      Int @default(0) // distinct school days in window

  // { parenting: "1/2", pengajian: null } — parent event attendance (free-text fractions)
  parentMeetingAttendance Json?

  // Hafalan free-text (Quran surah / hadis / doa list) — structured tracking deferred
  memorizationNotes String?

  // Internal signatures (audit trail; not legal e-signature) — unwired in MVP
  walasSignedAt  DateTime?
  kepalaSignedAt DateTime?

  // Parent post-publish workflow — unwired in MVP
  parentComment  String?
  parentSignedAt DateTime?

  status      String    @default("DRAFT") // DRAFT | PUBLISHED
  publishedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  term    Term    @relation(fields: [termId], references: [id], onDelete: Restrict)

  @@unique([tenantId, studentId, termId])
  @@index([tenantId, termId])
  @@index([tenantId, studentId])
}

/// Optional height/weight per student per term (raport header metadata).
model StudentMeasurement {
  id         String    @id @default(cuid())
  tenantId   String
  studentId  String
  termId     String
  heightCm   Decimal?  @db.Decimal(5, 1)
  weightKg   Decimal?  @db.Decimal(4, 1)
  recordedAt DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  term    Term    @relation(fields: [termId], references: [id], onDelete: Restrict)

  @@unique([tenantId, studentId, termId])
  @@index([tenantId, termId])
}
