#!/usr/bin/env bash
# pre-commit — enforce one-file-per-cycle + doc sync + seed drift check
#
# Three rules:
#  1. Markdown allowlist: any staged .md file must be in the allowlist below.
#     The allowlist is: README.md, CLAUDE.md, LICENSE.md at repo root;
#     anything under docs/, .github/, .claude/, .agent-skills/.
#  2. Doc sync: if any staged file touches app/, components/, lib/, prisma/,
#     app/api/ — then the commit must also stage README.md, CLAUDE.md, or a
#     docs/cycles/*.md file.
#  3. Seed drift: if prisma/seed.ts is staged, lib/db.ts must also be staged.
#     This forces authors to keep the seed's Prisma adapter in sync with lib/db.ts.
#
# Bypass: git commit --no-verify (discouraged; GitHub branch protection on
# staging/main is the real enforcement layer).

set -eu

# Only run if hooks are installed
if [ ! -f .githooks/.installed ]; then
  echo "pre-commit: .githooks/.installed marker missing. Run scripts/install-hooks.sh." >&2
  exit 1
fi

STAGED=$(git diff --cached --name-only --diff-filter=ACM)
[ -z "$STAGED" ] && exit 0

# ---------- Rule 1: Markdown allowlist ----------
BAD_MD=""
while IFS= read -r f; do
  case "$f" in
    *.md|*.mdx) ;;
    *) continue ;;
  esac
  case "$f" in
    README.md|CLAUDE.md|LICENSE.md|CHANGELOG.md|CONTRIBUTING.md) continue ;;
    docs/*) continue ;;
    .github/*) continue ;;
    .claude/*) continue ;;
    .agent-skills/*) continue ;;
    .githooks/*) continue ;;
    *) BAD_MD="$BAD_MD $f" ;;
  esac
done <<EOF
$STAGED
EOF

if [ -n "$BAD_MD" ]; then
  echo "pre-commit: markdown files outside the allowlist are not permitted." >&2
  echo "  Rejected:" >&2
  for f in $BAD_MD; do echo "    - $f" >&2; done
  echo "" >&2
  echo "  Allowed locations:" >&2
  echo "    README.md, CLAUDE.md, LICENSE.md, CHANGELOG.md, CONTRIBUTING.md (root)" >&2
  echo "    docs/** (including docs/cycles/YYYY-MM-DD-<slug>.md)" >&2
  echo "    .github/**, .claude/**, .agent-skills/**, .githooks/**" >&2
  echo "" >&2
  echo "  If you need to record cycle notes, edit the current cycle doc in docs/cycles/." >&2
  exit 1
fi

# ---------- Rule 2: Doc sync ----------
TOUCHES_CODE=0
TOUCHES_DOC=0
while IFS= read -r f; do
  case "$f" in
    app/*|components/*|lib/*|prisma/*) TOUCHES_CODE=1 ;;
  esac
  case "$f" in
    README.md|CLAUDE.md|docs/cycles/*.md) TOUCHES_DOC=1 ;;
  esac
done <<EOF
$STAGED
EOF

if [ "$TOUCHES_CODE" = "1" ] && [ "$TOUCHES_DOC" = "0" ]; then
  echo "pre-commit: code changes must be accompanied by a docs update." >&2
  echo "" >&2
  echo "  Stage at least one of:" >&2
  echo "    - docs/cycles/YYYY-MM-DD-<slug>.md  (this cycle's doc)" >&2
  echo "    - README.md                          (project map changes)" >&2
  echo "    - CLAUDE.md                          (AI operating manual changes)" >&2
  echo "" >&2
  echo "  This is enforced so docs stay in sync with code. The /build and /ship" >&2
  echo "  slash commands update the cycle doc automatically — use them." >&2
  exit 1
fi

# ---------- Rule 3: Seed drift prevention ----------
# If prisma/seed.ts is staged, lib/db.ts must also be staged.
# The seed and lib/db.ts must use the same Prisma adapter — a drift causes CI failures.
SEED_TOUCHED=0
DB_TOUCHED=0
while IFS= read -r f; do
  case "$f" in
    prisma/seed.ts) SEED_TOUCHED=1 ;;
    lib/db.ts) DB_TOUCHED=1 ;;
  esac
done <<EOF
$STAGED
EOF

if [ "$SEED_TOUCHED" = "1" ] && [ "$DB_TOUCHED" = "0" ]; then
  echo "pre-commit: prisma/seed.ts is staged but lib/db.ts is not." >&2
  echo "" >&2
  echo "  These two files MUST use the same Prisma adapter. If you change the" >&2
  echo "  seed, you must also stage lib/db.ts (even if unchanged) to confirm" >&2
  echo "  you've verified adapter parity." >&2
  echo "" >&2
  echo "  Fix: git add lib/db.ts" >&2
  exit 1
fi

exit 0
