build.log
build-analyze.log
tsconfig.tsbuildinfo

# Reference material (large xlsx, third-party repos, etc.) — kept locally, never committed
artifacts/

# Third-party agent skill plugins (loaded from ~/.claude/, not this repo)
.agents/

# Brainstorm visual companion artifacts (per-session, ephemeral)
.superpowers/

# Playwright output
playwright-report/
test-results/

.playwright-mcp/
.vercel

# Local storage adapter uploads (lib/storage). Files written here are served
