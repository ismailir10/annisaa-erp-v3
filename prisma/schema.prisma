// School ERP — v2 schema (greenfield, post-Phase-0 hard delete).
// Authority: docs/superpowers/specs/2026-05-04-erp-rebuild-foundation-design.md
// This file holds only what migrations 00 + 01 introduce; subsequent phase 1 cycles
// extend it (identity, employees, classes, sessions, audit, files).

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Enums (Postgres-native, engineer-controlled) ─────────────
// Per spec §4.2 (~34 enums planned). Cycle p1-identity-rls introduces 3.

enum PermissionScope {
  ALL
  OWN_CAMPUS
  OWN_PROGRAM
  OWN_CLASS
  OWN_SESSION
  OWN_STUDENT
  SELF
}

enum CatalogSource {
  SYSTEM
  ADMIN
}

enum TenantBootstrapStatus {
  PENDING
  COMPLETE
}

// Cycle p1-regions-seed introduces RegencyType.
enum RegencyType {
  KABUPATEN
  KOTA
}

// Cycle p1-employees-classes-sentra introduces SessionStatus + SessionTeacherRole
// per spec §4.2 + §4.5 critical pattern (PRIMARY/SUBSTITUTE/SENTRA/ASSISTANT).
enum SessionStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum SessionTeacherRole {
  PRIMARY
  SUBSTITUTE
  SENTRA
  ASSISTANT
}

// ── Tenant ───────────────────────────────────────────────────
// Root entity. No tenantId on itself, no soft-delete (tenant termination is operational).

model Tenant {
  id              String                @id @default(cuid())
  name            String                @db.VarChar(255)
  slug            String                @unique @db.VarChar(50)
  bootstrapStatus TenantBootstrapStatus @default(PENDING)
  createdAt       DateTime              @default(now()) @db.Timestamptz()
  updatedAt       DateTime              @updatedAt @db.Timestamptz()

  campuses      Campus[]
  programs      Program[]
  academicYears AcademicYear[]
  academicTerms AcademicTerm[]
  users         User[]
  roles         Role[]
  permissions   Permission[]
  employees     Employee[]
  classSections ClassSection[]
  sentras       Sentra[]
  classSessions ClassSession[]
}

// ── Campus ───────────────────────────────────────────────────

model Campus {
  id          String    @id @default(cuid())
  tenantId    String
  code        String    @db.VarChar(50)
  name        String    @db.VarChar(255)
  address     String?   @db.VarChar(500)
  phone       String?   @db.VarChar(20)
  email       String?   @db.VarChar(255)
  createdAt   DateTime  @default(now()) @db.Timestamptz()
  createdById String?
  updatedAt   DateTime  @updatedAt @db.Timestamptz()
  updatedById String?
  deletedAt   DateTime? @db.Timestamptz()
  deletedById String?

  tenant              Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  employeeAssignments EmployeeCampusAssignment[]
  classSections       ClassSection[]

  // Composite unique on (id, tenantId) backfilled in 03_employees migration.
  // Required as FK target for EmployeeCampusAssignment composite-FK chain (§6.4).
  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([tenantId, code])
}

// ── Program ──────────────────────────────────────────────────

model Program {
  id             String    @id @default(cuid())
  tenantId       String
  code           String    @db.VarChar(50)
  name           String    @db.VarChar(255)
  ageMonthsMin   Int
  ageMonthsMax   Int
  displayOrder   Int       @default(0)
  headEmployeeId String?
  createdAt      DateTime  @default(now()) @db.Timestamptz()
  createdById    String?
  updatedAt      DateTime  @updatedAt @db.Timestamptz()
  updatedById    String?
  deletedAt      DateTime? @db.Timestamptz()
  deletedById    String?

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  headEmployee  Employee?      @relation("ProgramHead", fields: [headEmployeeId], references: [id], onDelete: SetNull)
  classSections ClassSection[]

  // Composite unique on (id, tenantId) backfilled in 04_classes migration.
  // Required as FK target for ClassSection composite-FK chain (§6.4).
  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([tenantId, code])
  @@index([headEmployeeId])
}

// ── AcademicYear ─────────────────────────────────────────────

model AcademicYear {
  id          String    @id @default(cuid())
  tenantId    String
  name        String    @db.VarChar(50)
  startDate   DateTime  @db.Date
  endDate     DateTime  @db.Date
  isCurrent   Boolean   @default(false)
  createdAt   DateTime  @default(now()) @db.Timestamptz()
  createdById String?
  updatedAt   DateTime  @updatedAt @db.Timestamptz()
  updatedById String?
  deletedAt   DateTime? @db.Timestamptz()
  deletedById String?

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  terms         AcademicTerm[]
  classSections ClassSection[]

  // Composite unique on (id, tenantId) backfilled in 04_classes migration.
  // Required as FK target for ClassSection composite-FK chain (§6.4).
  @@unique([id, tenantId])
  @@unique([tenantId, name])
  @@index([tenantId])
}

// ── AcademicTerm ─────────────────────────────────────────────
// No deletedAt — terms are immutable historical anchors.

model AcademicTerm {
  id             String   @id @default(cuid())
  tenantId       String
  academicYearId String
  code           String   @db.VarChar(20)
  name           String   @db.VarChar(255)
  startDate      DateTime @db.Date
  endDate        DateTime @db.Date
  raportDueAt    DateTime @db.Date
  isActive       Boolean  @default(false)
  createdAt      DateTime @default(now()) @db.Timestamptz()
  createdById    String?
  updatedAt      DateTime @updatedAt @db.Timestamptz()
  updatedById    String?

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  academicYear     AcademicYear      @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  teachingDefaults TeachingDefault[]
  sentraRotations  SentraRotation[]
  classSessions    ClassSession[]

  // Composite unique on (id, tenantId) backfilled in 04_classes migration.
  // Required as FK target for TeachingDefault / SentraRotation / ClassSession composite-FK chains (§6.4).
  @@unique([id, tenantId])
  @@unique([tenantId, academicYearId, code])
  @@index([tenantId])
  @@index([academicYearId])
}

// ── User ─────────────────────────────────────────────────────
// Identity row. supabaseUserId binds to Supabase Auth post-OAuth callback
// (p1-auth-google-oauth). googleSubjectId stored for re-linking and audit.

model User {
  id              String    @id @default(cuid())
  tenantId        String
  email           String    @db.VarChar(255)
  name            String    @db.VarChar(255)
  googleSubjectId String?   @db.VarChar(255)
  supabaseUserId  String?   @db.VarChar(255)
  lastLoginAt     DateTime? @db.Timestamptz()
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now()) @db.Timestamptz()
  createdById     String?
  updatedAt       DateTime  @updatedAt @db.Timestamptz()
  updatedById     String?
  deletedAt       DateTime? @db.Timestamptz()
  deletedById     String?

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  userRoles UserRole[]

  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([tenantId, supabaseUserId])
  @@index([tenantId, googleSubjectId])
}

// ── Role ─────────────────────────────────────────────────────
// Catalog table per spec §4.3. SYSTEM rows seed-managed, ADMIN rows mutable
// in admin UI (post-launch). Soft-delete to preserve audit history when admin
// retires a role.

model Role {
  id          String        @id @default(cuid())
  tenantId    String
  code        String        @db.VarChar(50)
  name        String        @db.VarChar(255)
  source      CatalogSource @default(SYSTEM)
  createdAt   DateTime      @default(now()) @db.Timestamptz()
  createdById String?
  updatedAt   DateTime      @updatedAt @db.Timestamptz()
  updatedById String?
  deletedAt   DateTime?     @db.Timestamptz()
  deletedById String?

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([id, tenantId])
  @@index([tenantId])
}

// ── Permission ───────────────────────────────────────────────
// (resource, action, scope) tuple. Full per-role matrix lands in
// p1-scaffold-engine-skeleton when entity registry exists.

model Permission {
  id          String          @id @default(cuid())
  tenantId    String
  resource    String          @db.VarChar(50)
  action      String          @db.VarChar(50)
  scope       PermissionScope @default(ALL)
  createdAt   DateTime        @default(now()) @db.Timestamptz()
  createdById String?
  updatedAt   DateTime        @updatedAt @db.Timestamptz()
  updatedById String?
  deletedAt   DateTime?       @db.Timestamptz()
  deletedById String?

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  rolePermissions RolePermission[]

  @@unique([id, tenantId])
  @@index([tenantId])
}

// ── UserRole ─────────────────────────────────────────────────
// Composite-FK join per spec §6.4 — tenantId aligned with both User and Role.
// No soft-delete (cascade on User/Role retire is correct).

model UserRole {
  userId      String
  roleId      String
  tenantId    String
  createdAt   DateTime @default(now()) @db.Timestamptz()
  createdById String?

  user User @relation(fields: [userId, tenantId], references: [id, tenantId], onDelete: Cascade)
  role Role @relation(fields: [roleId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@id([userId, roleId, tenantId])
  @@index([tenantId])
  @@index([roleId, tenantId])
}

// ── RolePermission ───────────────────────────────────────────
// Composite-FK join per spec §6.4.

model RolePermission {
  roleId       String
  permissionId String
  tenantId     String
  createdAt    DateTime @default(now()) @db.Timestamptz()

  role       Role       @relation(fields: [roleId, tenantId], references: [id, tenantId], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@id([roleId, permissionId, tenantId])
  @@index([tenantId])
  @@index([permissionId, tenantId])
}

// ── Regions (Indonesian administrative reference data) ───────
// Per spec §4.1 row "Regions" + §4.2 enum RegencyType. Source: idn-area-data v4.0.1.
// Non-tenant-scoped global reference data (no tenantId, no soft-delete, no audit-by).
// BPS-code primary keys (deterministic). District uses CHAR(6) — idn-area-data ships
// the older PPRRDD form, not Permendagri-137 PPRRDDD; padding to 7 would break the
// Village(10) ⊃ District prefix chain. Documented in cycle 2026-05-05-p1-regions-seed.
// RLS: public-read (authenticated + anon SELECT) — admission form /daftar lands p2.

model Province {
  id        String   @id @db.Char(2)
  name      String   @db.VarChar(255)
  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()

  regencies Regency[]
}

model Regency {
  id         String      @id @db.Char(4)
  provinceId String      @db.Char(2)
  name       String      @db.VarChar(255)
  type       RegencyType
  createdAt  DateTime    @default(now()) @db.Timestamptz()
  updatedAt  DateTime    @updatedAt @db.Timestamptz()

  province  Province   @relation(fields: [provinceId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  districts District[]

  @@index([provinceId])
}

model District {
  id        String   @id @db.Char(6)
  regencyId String   @db.Char(4)
  name      String   @db.VarChar(255)
  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()

  regency  Regency   @relation(fields: [regencyId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  villages Village[]

  @@index([regencyId])
}

model Village {
  id         String   @id @db.Char(10)
  districtId String   @db.Char(6)
  name       String   @db.VarChar(255)
  createdAt  DateTime @default(now()) @db.Timestamptz()
  updatedAt  DateTime @updatedAt @db.Timestamptz()

  district District @relation(fields: [districtId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([districtId])
}

// ════════════════════════════════════════════════════════════════════════
// Cycle p1-employees-classes-sentra (foundation spec §6.1 mig 03+04+05)
// ════════════════════════════════════════════════════════════════════════

// ── Employee ─────────────────────────────────────────────────
// Staff record. supabaseUserId / googleSubjectId mirror User for OAuth bind
// post-`p1-auth-google-oauth`. NIK = Indonesian national ID (PII, hashable;
// 16-digit format). jobTitle inline VARCHAR(50) — JobTitle catalog deferred
// per spec §4.3 catalog list (MVP excludes JobTitle).

model Employee {
  id              String    @id @default(cuid())
  tenantId        String
  email           String    @db.VarChar(255)
  name            String    @db.VarChar(255)
  nik             String?   @db.VarChar(16) /// @PII redact
  phone           String?   @db.VarChar(20)
  jobTitle        String?   @db.VarChar(50)
  supabaseUserId  String?   @db.VarChar(255)
  googleSubjectId String?   @db.VarChar(255)
  isActive        Boolean   @default(true)
  hiredAt         DateTime? @db.Date
  terminatedAt    DateTime? @db.Date
  version         Int       @default(0)
  createdAt       DateTime  @default(now()) @db.Timestamptz()
  createdById     String?
  updatedAt       DateTime  @updatedAt @db.Timestamptz()
  updatedById     String?
  deletedAt       DateTime? @db.Timestamptz()
  deletedById     String?

  tenant               Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  campusAssignments    EmployeeCampusAssignment[]
  walasOfClassSections ClassSection[]             @relation("ClassSectionWalas")
  teachingDefaults     TeachingDefault[]
  sessionTeachers      SessionTeacher[]
  headOfPrograms       Program[]                  @relation("ProgramHead")

  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([tenantId, supabaseUserId])
  @@index([tenantId, googleSubjectId])
  @@index([tenantId, isActive])
}

// ── EmployeeCampusAssignment ─────────────────────────────────
// Composite-FK join per §6.4. Tracks which campus(es) an employee works at +
// optional campus-level role. Cascade on Employee/Campus delete (assignment
// has no meaning without parent). No soft-delete — historical assignments
// captured via endDate, hard-delete is a data correction.

model EmployeeCampusAssignment {
  employeeId  String
  campusId    String
  tenantId    String
  role        String?   @db.VarChar(50)
  isPrimary   Boolean   @default(true)
  startDate   DateTime  @db.Date
  endDate     DateTime? @db.Date
  createdAt   DateTime  @default(now()) @db.Timestamptz()
  createdById String?

  employee Employee @relation(fields: [employeeId, tenantId], references: [id, tenantId], onDelete: Cascade)
  campus   Campus   @relation(fields: [campusId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@id([employeeId, campusId, tenantId])
  @@index([tenantId])
  @@index([campusId, tenantId])
}

// ── ClassSection ─────────────────────────────────────────────
// A class within a Program for a given AcademicYear at a given Campus.
// walasEmployeeId is single-col FK SET NULL (column FK, not join table —
// composite reserved for join tables per §6.4). Tenant alignment enforced
// app-layer via ClassSection.tenantId denorm.
// `version Int` shipped now ahead of `17_version_triggers` migration per §4.4.

model ClassSection {
  id              String    @id @default(cuid())
  tenantId        String
  programId       String
  academicYearId  String
  campusId        String
  walasEmployeeId String?
  code            String    @db.VarChar(50)
  name            String    @db.VarChar(255)
  displayOrder    Int       @default(0)
  capacity        Int?
  version         Int       @default(0)
  createdAt       DateTime  @default(now()) @db.Timestamptz()
  createdById     String?
  updatedAt       DateTime  @updatedAt @db.Timestamptz()
  updatedById     String?
  deletedAt       DateTime? @db.Timestamptz()
  deletedById     String?

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  program          Program           @relation(fields: [programId, tenantId], references: [id, tenantId], onDelete: Restrict)
  academicYear     AcademicYear      @relation(fields: [academicYearId, tenantId], references: [id, tenantId], onDelete: Restrict)
  campus           Campus            @relation(fields: [campusId, tenantId], references: [id, tenantId], onDelete: Restrict)
  walas            Employee?         @relation("ClassSectionWalas", fields: [walasEmployeeId], references: [id], onDelete: SetNull)
  teachingDefaults TeachingDefault[]
  sentraRotations  SentraRotation[]
  classSessions    ClassSession[]

  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([tenantId, programId])
  @@index([tenantId, academicYearId])
  @@index([tenantId, campusId])
  @@index([walasEmployeeId])
}

// ── Sentra ───────────────────────────────────────────────────
// Catalog table per spec §4.3 (PAUD learning-center category — Persiapan,
// Balok, Bahan Alam, Main Peran, Seni, Imtaq, Memasak, Olah Tubuh).
// SYSTEM-seeded; admin can extend in v1.1+.

model Sentra {
  id           String        @id @default(cuid())
  tenantId     String
  code         String        @db.VarChar(50)
  name         String        @db.VarChar(255)
  source       CatalogSource @default(SYSTEM)
  displayOrder Int           @default(0)
  createdAt    DateTime      @default(now()) @db.Timestamptz()
  createdById  String?
  updatedAt    DateTime      @updatedAt @db.Timestamptz()
  updatedById  String?
  deletedAt    DateTime?     @db.Timestamptz()
  deletedById  String?

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  teachingDefaults TeachingDefault[]
  sentraRotations  SentraRotation[]
  classSessions    ClassSession[]

  @@unique([id, tenantId])
  @@index([tenantId])
}

// ── TeachingDefault ──────────────────────────────────────────
// Composite-FK join per §6.4. Default sentra-teacher mapping per (class ×
// sentra × term). Overwritten per term — no soft-delete. Cascade on parent
// delete invalidates the mapping.

model TeachingDefault {
  classSectionId String
  academicTermId String
  sentraId       String
  employeeId     String
  tenantId       String
  createdAt      DateTime @default(now()) @db.Timestamptz()
  createdById    String?

  classSection ClassSection @relation(fields: [classSectionId, tenantId], references: [id, tenantId], onDelete: Cascade)
  academicTerm AcademicTerm @relation(fields: [academicTermId, tenantId], references: [id, tenantId], onDelete: Cascade)
  sentra       Sentra       @relation(fields: [sentraId, tenantId], references: [id, tenantId], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@id([classSectionId, academicTermId, sentraId, tenantId])
  @@index([tenantId])
  @@index([employeeId, tenantId])
  @@index([sentraId, tenantId])
  @@index([academicTermId, tenantId])
}

// ── SentraRotation ───────────────────────────────────────────
// Composite-FK join per §6.4. Week-grid mapping (class × dayOfWeek × term →
// sentra). dayOfWeek ISO 8601 (Mon=1 … Sun=7). No soft-delete — overwritten
// per term.

model SentraRotation {
  classSectionId String
  dayOfWeek      Int
  academicTermId String
  sentraId       String
  tenantId       String
  createdAt      DateTime @default(now()) @db.Timestamptz()
  createdById    String?

  classSection ClassSection @relation(fields: [classSectionId, tenantId], references: [id, tenantId], onDelete: Cascade)
  academicTerm AcademicTerm @relation(fields: [academicTermId, tenantId], references: [id, tenantId], onDelete: Cascade)
  sentra       Sentra       @relation(fields: [sentraId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@id([classSectionId, dayOfWeek, academicTermId, tenantId])
  @@index([tenantId])
  @@index([sentraId, tenantId])
  @@index([academicTermId, tenantId])
}

// ── ClassSession ─────────────────────────────────────────────
// One per class-day per AcademicTerm. status enum tracks operational
// lifecycle. sentraId is denorm of effective sentra (derived from
// SentraRotation but stored for query efficiency + override). No soft-delete
// (operational record). Restrict on ClassSection delete — admin must archive
// section before sessions can be removed.
// `version Int` shipped now ahead of `17_version_triggers` per §4.4.

model ClassSession {
  id             String        @id @default(cuid())
  tenantId       String
  classSectionId String
  academicTermId String
  sessionDate    DateTime      @db.Date
  dayOfWeek      Int
  sentraId       String?
  status         SessionStatus @default(PLANNED)
  startedAt      DateTime?     @db.Timestamptz()
  completedAt    DateTime?     @db.Timestamptz()
  notes          String?       @db.VarChar(2000)
  version        Int           @default(0)
  createdAt      DateTime      @default(now()) @db.Timestamptz()
  createdById    String?
  updatedAt      DateTime      @updatedAt @db.Timestamptz()
  updatedById    String?

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  classSection    ClassSection     @relation(fields: [classSectionId, tenantId], references: [id, tenantId], onDelete: Restrict)
  academicTerm    AcademicTerm     @relation(fields: [academicTermId, tenantId], references: [id, tenantId], onDelete: Restrict)
  sentra          Sentra?          @relation(fields: [sentraId], references: [id], onDelete: SetNull)
  sessionTeachers SessionTeacher[]

  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([tenantId, academicTermId])
  @@index([tenantId, sessionDate])
  @@index([tenantId, classSectionId, sessionDate])
  @@index([tenantId, status])
  @@index([sentraId, tenantId])
}

// ── SessionTeacher ───────────────────────────────────────────
// Composite-FK join per §6.4. Cascade on session/employee delete per §4.4
// "Cascade for owned children (SessionTeacher, UserRole)". role enum
// PRIMARY/SUBSTITUTE/SENTRA/ASSISTANT per spec §4.5. Single-PRIMARY-per-
// session enforced via partial unique index in 05_sessions migration
// (DSL doesn't express partial uniques).

model SessionTeacher {
  sessionId   String
  employeeId  String
  role        SessionTeacherRole
  tenantId    String
  assignedAt  DateTime           @default(now()) @db.Timestamptz()
  createdById String?

  session  ClassSession @relation(fields: [sessionId, tenantId], references: [id, tenantId], onDelete: Cascade)
  employee Employee     @relation(fields: [employeeId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@id([sessionId, employeeId, role, tenantId])
  @@index([tenantId])
  @@index([employeeId, tenantId])
}
