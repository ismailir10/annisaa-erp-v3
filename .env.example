# Environment Variables
# Copy this file to .env.local and fill in your values

# Bundle Analyzer
# Set to "true" to enable bundle analysis during build
# ANALYZE=true

# Database (Supabase)
# DATABASE_URL="postgresql://..."           # Pooler (port 6543) for app runtime
# DIRECT_URL="postgresql://..."             # Direct (port 5432) — required on Vercel for prisma migrate deploy

# Supabase
# NEXT_PUBLIC_SUPABASE_URL="https://..."
# NEXT_PUBLIC_SUPABASE_ANON_KEY="..."
# SUPABASE_SERVICE_ROLE_KEY="..."           # Server-only — used by scripts/reseed-staging.ts and scripts/finish-xendit.ts

# Xendit Payment Gateway
# XENDIT_SECRET_KEY="..."                   # Tier auto-derived from prefix (xnd_development_ vs xnd_production_)
# NEXT_PUBLIC_XENDIT_PUBLIC_API_KEY="..."
# XENDIT_WEBHOOK_TOKEN="..."

# Resend Email Service
# RESEND_API_KEY="re_..."                   # Omit to simulate email sends in dev
# RESEND_FROM_EMAIL="Talib by An Nisaa' <noreply@annisaasekolahku.com>"
# STAGING_EMAIL_OVERRIDE="admin@example.test"  # Staging-only: redirect all outbound mail to this address

# App Configuration
# NEXT_PUBLIC_APP_URL="http://localhost:3000"  # Per-env; throws if missing on Vercel

# Cron
# CRON_SECRET="..."                         # openssl rand -hex 32; required by /api/cron/* routes
