// School ERP — v2 schema (greenfield, post-Phase-0 hard delete).
// Authority: docs/superpowers/specs/2026-05-04-erp-rebuild-foundation-design.md
// This file holds only what migrations 00 + 01 introduce; subsequent phase 1 cycles
// extend it (identity, employees, classes, sessions, audit, files).

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Tenant ───────────────────────────────────────────────────
// Root entity. No tenantId on itself, no soft-delete (tenant termination is operational).

model Tenant {
  id              String   @id @default(cuid())
  name            String   @db.VarChar(255)
  slug            String   @unique @db.VarChar(50)
  bootstrapStatus String   @default("PENDING") @db.VarChar(20)
  createdAt       DateTime @default(now()) @db.Timestamptz()
  updatedAt       DateTime @updatedAt @db.Timestamptz()

  campuses      Campus[]
  programs      Program[]
  academicYears AcademicYear[]
  academicTerms AcademicTerm[]
}

// ── Campus ───────────────────────────────────────────────────

model Campus {
  id          String    @id @default(cuid())
  tenantId    String
  code        String    @db.VarChar(50)
  name        String    @db.VarChar(255)
  address     String?   @db.VarChar(500)
  phone       String?   @db.VarChar(20)
  email       String?   @db.VarChar(255)
  createdAt   DateTime  @default(now()) @db.Timestamptz()
  createdById String?
  updatedAt   DateTime  @updatedAt @db.Timestamptz()
  updatedById String?
  deletedAt   DateTime? @db.Timestamptz()
  deletedById String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, code])
}

// ── Program ──────────────────────────────────────────────────

model Program {
  id             String    @id @default(cuid())
  tenantId       String
  code           String    @db.VarChar(50)
  name           String    @db.VarChar(255)
  ageMonthsMin   Int
  ageMonthsMax   Int
  displayOrder   Int       @default(0)
  headEmployeeId String?
  createdAt      DateTime  @default(now()) @db.Timestamptz()
  createdById    String?
  updatedAt      DateTime  @updatedAt @db.Timestamptz()
  updatedById    String?
  deletedAt      DateTime? @db.Timestamptz()
  deletedById    String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, code])
  @@index([headEmployeeId])
}

// ── AcademicYear ─────────────────────────────────────────────

model AcademicYear {
  id          String    @id @default(cuid())
  tenantId    String
  name        String    @db.VarChar(50)
  startDate   DateTime  @db.Date
  endDate     DateTime  @db.Date
  isCurrent   Boolean   @default(false)
  createdAt   DateTime  @default(now()) @db.Timestamptz()
  createdById String?
  updatedAt   DateTime  @updatedAt @db.Timestamptz()
  updatedById String?
  deletedAt   DateTime? @db.Timestamptz()
  deletedById String?

  tenant Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  terms  AcademicTerm[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

// ── AcademicTerm ─────────────────────────────────────────────
// No deletedAt — terms are immutable historical anchors.

model AcademicTerm {
  id             String   @id @default(cuid())
  tenantId       String
  academicYearId String
  code           String   @db.VarChar(20)
  name           String   @db.VarChar(255)
  startDate      DateTime @db.Date
  endDate        DateTime @db.Date
  raportDueAt    DateTime @db.Date
  isActive       Boolean  @default(false)
  createdAt      DateTime @default(now()) @db.Timestamptz()
  createdById    String?
  updatedAt      DateTime @updatedAt @db.Timestamptz()
  updatedById    String?

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Restrict)

  @@unique([tenantId, academicYearId, code])
  @@index([tenantId])
  @@index([academicYearId])
}
