#!/usr/bin/env bash
# pre-push — block direct pushes to staging and main for ALL roles
#
# No one pushes staging or main directly — not even cto. All changes flow
# through PRs created by /ship. GitHub branch protection is the real
# enforcement layer; this hook is a local early-warning guard.
#
# Feature branches (feat/*) are always allowed.
#
# Bypass: git push --no-verify (discouraged). GitHub branch protection on
# staging/main will still reject it if configured.
#
# Arguments from git: <remote> <url>
# stdin lines: <local_ref> <local_sha> <remote_ref> <remote_sha>

set -eu

REMOTE="${1:-}"
PROTECTED_REFS="refs/heads/staging refs/heads/main"

# Read session role for informational context
ROLE_FILE=".claude/session-role"
ROLE="unknown"
MODEL="unknown"
if [ -f "$ROLE_FILE" ]; then
  ROLE=$(grep '^role=' "$ROLE_FILE" 2>/dev/null | head -1 | cut -d= -f2- || echo "unknown")
  MODEL=$(grep '^model=' "$ROLE_FILE" 2>/dev/null | head -1 | cut -d= -f2- || echo "unknown")
fi

# Read refs from stdin
BLOCKED=0
BLOCKED_REF=""
while read -r LOCAL_REF LOCAL_SHA REMOTE_REF REMOTE_SHA; do
  for p in $PROTECTED_REFS; do
    if [ "$REMOTE_REF" = "$p" ]; then
      echo "pre-push: BLOCKED direct push to $REMOTE_REF (role=$ROLE, model=$MODEL)" >&2
      BLOCKED=1
      BLOCKED_REF="$REMOTE_REF"
    fi
  done
done

if [ "$BLOCKED" = "1" ]; then
  cat >&2 <<EOF

Direct pushes to staging and main are disabled for all roles.
Use /ship to open a PR instead — it handles push + PR creation automatically.

Your current session: role=$ROLE, model=$MODEL
Blocked ref: $BLOCKED_REF

To ship manually:
  1. Push your feature branch:
       git push -u origin feat/<slug>
  2. Open a PR to staging:
       gh pr create --base staging

Or run /ship — it does all of the above automatically.
For staging → main: /ship --to-main (CTO-initiated only).

Emergency override: git push --no-verify
(GitHub branch protection will still reject it if configured.)

EOF
  exit 1
fi

exit 0
