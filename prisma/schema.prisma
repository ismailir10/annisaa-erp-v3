// School ERP — v2 schema (greenfield, post-Phase-0 hard delete).
// Authority: docs/superpowers/specs/2026-05-04-erp-rebuild-foundation-design.md
// This file holds only what migrations 00 + 01 introduce; subsequent phase 1 cycles
// extend it (identity, employees, classes, sessions, audit, files).

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Enums (Postgres-native, engineer-controlled) ─────────────
// Per spec §4.2 (~34 enums planned). Cycle p1-identity-rls introduces 3.

enum PermissionScope {
  ALL
  OWN_CAMPUS
  OWN_PROGRAM
  OWN_CLASS
  OWN_SESSION
  OWN_STUDENT
  SELF
}

enum CatalogSource {
  SYSTEM
  ADMIN
}

enum TenantBootstrapStatus {
  PENDING
  COMPLETE
}

// Cycle p1-regions-seed introduces RegencyType.
enum RegencyType {
  KABUPATEN
  KOTA
}

// Cycle p1-employees-classes-sentra introduces SessionStatus + SessionTeacherRole
// per spec §4.2 + §4.5 critical pattern (PRIMARY/SUBSTITUTE/SENTRA/ASSISTANT).
enum SessionStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum SessionTeacherRole {
  PRIMARY
  SUBSTITUTE
  SENTRA
  ASSISTANT
}

// Cycle p1-audit-timeline-files introduces 6 enums per spec §4.2:
// AuditAction (CRUD + soft-delete + read + import + export tracking),
// TimelineVisibility (PRIVATE/INTERNAL/PARENT_VISIBLE — admin/teacher/parent visibility tiers),
// FileKind (DOCUMENT/IMAGE/VIDEO/AUDIO/ARCHIVE),
// FileStatus (lifecycle for §16.1a file_asset.orphan_cleanup cron),
// ExportFormat (per §5.11 async export),
// ExportJobStatus (state machine per §5.11).

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  SOFT_DELETE
  RESTORE
  READ
  IMPORT
  EXPORT
}

enum TimelineVisibility {
  PRIVATE
  INTERNAL
  PARENT_VISIBLE
}

enum FileKind {
  DOCUMENT
  IMAGE
  VIDEO
  AUDIO
  ARCHIVE
}

enum FileStatus {
  PENDING_UPLOAD
  UPLOADED
  COMPRESSED
  FAILED
  ORPHANED
}

enum ExportFormat {
  CSV
  XLSX
  PDF
}

enum ExportJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  EXPIRED
}

// ── Tenant ───────────────────────────────────────────────────
// Root entity. No tenantId on itself, no soft-delete (tenant termination is operational).

model Tenant {
  id              String                @id @default(cuid())
  name            String                @db.VarChar(255)
  slug            String                @unique @db.VarChar(50)
  bootstrapStatus TenantBootstrapStatus @default(PENDING)
  createdAt       DateTime              @default(now()) @db.Timestamptz()
  updatedAt       DateTime              @updatedAt @db.Timestamptz()

  campuses                   Campus[]
  programs                   Program[]
  academicYears              AcademicYear[]
  academicTerms              AcademicTerm[]
  users                      User[]
  roles                      Role[]
  permissions                Permission[]
  employees                  Employee[]
  classSections              ClassSection[]
  sentras                    Sentra[]
  classSessions              ClassSession[]
  auditLogs                  AuditLog[]
  timelineEvents             TimelineEvent[]
  fileAssets                 FileAsset[]
  exportJobs                 ExportJob[]
  emailLogs                  EmailLog[]
  webhookEvents              WebhookEvent[]
  orgConfig                  OrgConfig?
  holidays                   Holiday[]
  households                 Household[]
  students                   Student[]
  studentIdentifiers         StudentIdentifier[]
  studentIdentifierSequences StudentIdentifierSequence[]
  guardians                  Guardian[]
  studentGuardians           StudentGuardian[]
  guardianInvitations        GuardianInvitation[]
  addresses                  Address[]
}

// ── Campus ───────────────────────────────────────────────────

model Campus {
  id          String    @id @default(cuid())
  tenantId    String
  code        String    @db.VarChar(50)
  name        String    @db.VarChar(255)
  address     String?   @db.VarChar(500)
  phone       String?   @db.VarChar(20)
  email       String?   @db.VarChar(255)
  createdAt   DateTime  @default(now()) @db.Timestamptz()
  createdById String?
  updatedAt   DateTime  @updatedAt @db.Timestamptz()
  updatedById String?
  deletedAt   DateTime? @db.Timestamptz()
  deletedById String?

  tenant              Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  employeeAssignments EmployeeCampusAssignment[]
  classSections       ClassSection[]

  // Composite unique on (id, tenantId) backfilled in 03_employees migration.
  // Required as FK target for EmployeeCampusAssignment composite-FK chain (§6.4).
  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([tenantId, code])
}

// ── Program ──────────────────────────────────────────────────

model Program {
  id             String    @id @default(cuid())
  tenantId       String
  code           String    @db.VarChar(50)
  name           String    @db.VarChar(255)
  ageMonthsMin   Int
  ageMonthsMax   Int
  displayOrder   Int       @default(0)
  headEmployeeId String?
  createdAt      DateTime  @default(now()) @db.Timestamptz()
  createdById    String?
  updatedAt      DateTime  @updatedAt @db.Timestamptz()
  updatedById    String?
  deletedAt      DateTime? @db.Timestamptz()
  deletedById    String?

  tenant                     Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  headEmployee               Employee?                   @relation("ProgramHead", fields: [headEmployeeId], references: [id], onDelete: SetNull)
  classSections              ClassSection[]
  students                   Student[]
  studentIdentifierSequences StudentIdentifierSequence[]

  // Composite unique on (id, tenantId) backfilled in 04_classes migration.
  // Required as FK target for ClassSection composite-FK chain (§6.4).
  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([tenantId, code])
  @@index([headEmployeeId])
}

// ── AcademicYear ─────────────────────────────────────────────

model AcademicYear {
  id          String    @id @default(cuid())
  tenantId    String
  name        String    @db.VarChar(50)
  startDate   DateTime  @db.Date
  endDate     DateTime  @db.Date
  isCurrent   Boolean   @default(false)
  createdAt   DateTime  @default(now()) @db.Timestamptz()
  createdById String?
  updatedAt   DateTime  @updatedAt @db.Timestamptz()
  updatedById String?
  deletedAt   DateTime? @db.Timestamptz()
  deletedById String?

  tenant                     Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  terms                      AcademicTerm[]
  classSections              ClassSection[]
  currentForOrgConfigs       OrgConfig[]                 @relation("OrgConfigCurrentYear")
  studentIdentifierSequences StudentIdentifierSequence[]

  // Composite unique on (id, tenantId) backfilled in 04_classes migration.
  // Required as FK target for ClassSection composite-FK chain (§6.4) +
  // OrgConfig.currentAcademicYearId composite FK (§4.1 Foundation row, this cycle).
  @@unique([id, tenantId])
  @@unique([tenantId, name])
  @@index([tenantId])
}

// ── AcademicTerm ─────────────────────────────────────────────
// No deletedAt — terms are immutable historical anchors.

model AcademicTerm {
  id             String   @id @default(cuid())
  tenantId       String
  academicYearId String
  code           String   @db.VarChar(20)
  name           String   @db.VarChar(255)
  startDate      DateTime @db.Date
  endDate        DateTime @db.Date
  raportDueAt    DateTime @db.Date
  isActive       Boolean  @default(false)
  createdAt      DateTime @default(now()) @db.Timestamptz()
  createdById    String?
  updatedAt      DateTime @updatedAt @db.Timestamptz()
  updatedById    String?

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  academicYear     AcademicYear      @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  teachingDefaults TeachingDefault[]
  sentraRotations  SentraRotation[]
  classSessions    ClassSession[]

  // Composite unique on (id, tenantId) backfilled in 04_classes migration.
  // Required as FK target for TeachingDefault / SentraRotation / ClassSession composite-FK chains (§6.4).
  @@unique([id, tenantId])
  @@unique([tenantId, academicYearId, code])
  @@index([tenantId])
  @@index([academicYearId])
}

// ── User ─────────────────────────────────────────────────────
// Identity row. supabaseUserId binds to Supabase Auth post-OAuth callback
// (p1-auth-google-oauth). googleSubjectId stored for re-linking and audit.

model User {
  id              String    @id @default(cuid())
  tenantId        String
  email           String    @db.VarChar(255)
  name            String    @db.VarChar(255)
  googleSubjectId String?   @db.VarChar(255)
  supabaseUserId  String?   @db.VarChar(255)
  lastLoginAt     DateTime? @db.Timestamptz()
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now()) @db.Timestamptz()
  createdById     String?
  updatedAt       DateTime  @updatedAt @db.Timestamptz()
  updatedById     String?
  deletedAt       DateTime? @db.Timestamptz()
  deletedById     String?

  tenant             Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  userRoles          UserRole[]
  timelineEvents     TimelineEvent[] @relation("TimelineEventActor")
  uploadedFileAssets FileAsset[]     @relation("FileAssetUploader")
  exportJobs         ExportJob[]     @relation("ExportJobRequester")
  guardians          Guardian[]

  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([tenantId, supabaseUserId])
  @@index([tenantId, googleSubjectId])
}

// ── Role ─────────────────────────────────────────────────────
// Catalog table per spec §4.3. SYSTEM rows seed-managed, ADMIN rows mutable
// in admin UI (post-launch). Soft-delete to preserve audit history when admin
// retires a role.

model Role {
  id          String        @id @default(cuid())
  tenantId    String
  code        String        @db.VarChar(50)
  name        String        @db.VarChar(255)
  source      CatalogSource @default(SYSTEM)
  createdAt   DateTime      @default(now()) @db.Timestamptz()
  createdById String?
  updatedAt   DateTime      @updatedAt @db.Timestamptz()
  updatedById String?
  deletedAt   DateTime?     @db.Timestamptz()
  deletedById String?

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([id, tenantId])
  @@index([tenantId])
}

// ── Permission ───────────────────────────────────────────────
// (resource, action, scope) tuple. Full per-role matrix lands in
// p1-scaffold-engine-skeleton when entity registry exists.

model Permission {
  id          String          @id @default(cuid())
  tenantId    String
  resource    String          @db.VarChar(50)
  action      String          @db.VarChar(50)
  scope       PermissionScope @default(ALL)
  createdAt   DateTime        @default(now()) @db.Timestamptz()
  createdById String?
  updatedAt   DateTime        @updatedAt @db.Timestamptz()
  updatedById String?
  deletedAt   DateTime?       @db.Timestamptz()
  deletedById String?

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  rolePermissions RolePermission[]

  @@unique([id, tenantId])
  @@index([tenantId])
}

// ── UserRole ─────────────────────────────────────────────────
// Composite-FK join per spec §6.4 — tenantId aligned with both User and Role.
// No soft-delete (cascade on User/Role retire is correct).

model UserRole {
  userId      String
  roleId      String
  tenantId    String
  createdAt   DateTime @default(now()) @db.Timestamptz()
  createdById String?

  user User @relation(fields: [userId, tenantId], references: [id, tenantId], onDelete: Cascade)
  role Role @relation(fields: [roleId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@id([userId, roleId, tenantId])
  @@index([tenantId])
  @@index([roleId, tenantId])
}

// ── RolePermission ───────────────────────────────────────────
// Composite-FK join per spec §6.4.

model RolePermission {
  roleId       String
  permissionId String
  tenantId     String
  createdAt    DateTime @default(now()) @db.Timestamptz()

  role       Role       @relation(fields: [roleId, tenantId], references: [id, tenantId], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@id([roleId, permissionId, tenantId])
  @@index([tenantId])
  @@index([permissionId, tenantId])
}

// ── Regions (Indonesian administrative reference data) ───────
// Per spec §4.1 row "Regions" + §4.2 enum RegencyType. Source: idn-area-data v4.0.1.
// Non-tenant-scoped global reference data (no tenantId, no soft-delete, no audit-by).
// BPS-code primary keys (deterministic). District uses CHAR(6) — idn-area-data ships
// the older PPRRDD form, not Permendagri-137 PPRRDDD; padding to 7 would break the
// Village(10) ⊃ District prefix chain. Documented in cycle 2026-05-05-p1-regions-seed.
// RLS: public-read (authenticated + anon SELECT) — admission form /daftar lands p2.

model Province {
  id        String   @id @db.Char(2)
  name      String   @db.VarChar(255)
  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()

  regencies Regency[]
  addresses Address[]
}

model Regency {
  id         String      @id @db.Char(4)
  provinceId String      @db.Char(2)
  name       String      @db.VarChar(255)
  type       RegencyType
  createdAt  DateTime    @default(now()) @db.Timestamptz()
  updatedAt  DateTime    @updatedAt @db.Timestamptz()

  province  Province   @relation(fields: [provinceId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  districts District[]
  addresses Address[]

  @@unique([id, provinceId])
  @@index([provinceId])
}

model District {
  id        String   @id @db.Char(6)
  regencyId String   @db.Char(4)
  name      String   @db.VarChar(255)
  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()

  regency   Regency   @relation(fields: [regencyId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  villages  Village[]
  addresses Address[]

  @@unique([id, regencyId])
  @@index([regencyId])
}

model Village {
  id         String   @id @db.Char(10)
  districtId String   @db.Char(6)
  name       String   @db.VarChar(255)
  createdAt  DateTime @default(now()) @db.Timestamptz()
  updatedAt  DateTime @updatedAt @db.Timestamptz()

  district  District  @relation(fields: [districtId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  addresses Address[]

  @@unique([id, districtId])
  @@index([districtId])
}

// ── Address ──────────────────────────────────────────────────
// Per spec §6.1 + §6.4 composite-FK pattern. Tenant-scoped, soft-delete,
// audit per §4.4. Region chain (provinceId / regencyId / districtId /
// villageId) enforced via compound FKs at DB layer + Zod superRefine
// prefix-check at app layer (lowest-cost belt-and-braces; see cycle
// p2-addresses-idn-chain Spec §1).
//
// `villageId` is OPTIONAL — some PAUD parents don't know village
// granularity at admission time; addresses without village still satisfy
// the Indonesian administrative chain at District precision.
//
// `streetLine`, `notes` — operator free-text. `rt`/`rw`/`postalCode`
// optional. No /// @PII annotations this cycle (see cycle Spec §3).

model Address {
  id          String    @id @default(cuid())
  tenantId    String
  provinceId  String    @db.Char(2)
  regencyId   String    @db.Char(4)
  districtId  String    @db.Char(6)
  villageId   String?   @db.Char(10)
  streetLine  String    @db.VarChar(500)
  rt          String?   @db.VarChar(3)
  rw          String?   @db.VarChar(3)
  postalCode  String?   @db.VarChar(5)
  notes       String?   @db.VarChar(1000)
  createdAt   DateTime  @default(now()) @db.Timestamptz()
  createdById String?
  updatedAt   DateTime  @updatedAt @db.Timestamptz()
  updatedById String?
  deletedAt   DateTime? @db.Timestamptz()
  deletedById String?

  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  // Region FKs use SINGLE-column Prisma relations (NOT composite). DB-level
  // composite FKs in migration SQL enforce hierarchy (BPS prefix + row
  // existence). Composite Prisma relations on Restrict-only FKs are safe in
  // theory but trigger `prisma migrate dev` regenerating composite REFERENCES
  // mismatched to the migration's column-list ordering — single-column at
  // Prisma keeps the schema↔migration mapping unambiguous.
  province Province   @relation(fields: [provinceId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  regency  Regency    @relation(fields: [regencyId],  references: [id], onDelete: Restrict, onUpdate: Cascade)
  district District   @relation(fields: [districtId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  village  Village?   @relation(fields: [villageId],  references: [id], onDelete: Restrict, onUpdate: Cascade)
  households Household[]

  // Composite unique on (id, tenantId) — required as FK target for
  // Household.addressId composite-FK chain (§6.4).
  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([provinceId])
  @@index([regencyId, provinceId])
  @@index([districtId, regencyId])
  @@index([villageId, districtId])
}

// ════════════════════════════════════════════════════════════════════════
// Cycle p1-employees-classes-sentra (foundation spec §6.1 mig 03+04+05)
// ════════════════════════════════════════════════════════════════════════

// ── Employee ─────────────────────────────────────────────────
// Staff record. supabaseUserId / googleSubjectId mirror User for OAuth bind
// post-`p1-auth-google-oauth`. NIK = Indonesian national ID (PII, hashable;
// 16-digit format). jobTitle inline VARCHAR(50) — JobTitle catalog deferred
// per spec §4.3 catalog list (MVP excludes JobTitle).

model Employee {
  id              String    @id @default(cuid())
  tenantId        String
  email           String    @db.VarChar(255)
  name            String    @db.VarChar(255)
  nik             String?   @db.VarChar(16) /// @PII redact
  phone           String?   @db.VarChar(20) /// @PII mask:last4
  jobTitle        String?   @db.VarChar(50)
  supabaseUserId  String?   @db.VarChar(255)
  googleSubjectId String?   @db.VarChar(255)
  isActive        Boolean   @default(true)
  hiredAt         DateTime? @db.Date
  terminatedAt    DateTime? @db.Date
  version         Int       @default(0)
  createdAt       DateTime  @default(now()) @db.Timestamptz()
  createdById     String?
  updatedAt       DateTime  @updatedAt @db.Timestamptz()
  updatedById     String?
  deletedAt       DateTime? @db.Timestamptz()
  deletedById     String?

  tenant               Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  campusAssignments    EmployeeCampusAssignment[]
  walasOfClassSections ClassSection[]             @relation("ClassSectionWalas")
  teachingDefaults     TeachingDefault[]
  sessionTeachers      SessionTeacher[]
  headOfPrograms       Program[]                  @relation("ProgramHead")

  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([tenantId, supabaseUserId])
  @@index([tenantId, googleSubjectId])
  @@index([tenantId, isActive])
}

// ── EmployeeCampusAssignment ─────────────────────────────────
// Composite-FK join per §6.4. Tracks which campus(es) an employee works at +
// optional campus-level role. Cascade on Employee/Campus delete (assignment
// has no meaning without parent). No soft-delete — historical assignments
// captured via endDate, hard-delete is a data correction.

model EmployeeCampusAssignment {
  employeeId  String
  campusId    String
  tenantId    String
  role        String?   @db.VarChar(50)
  isPrimary   Boolean   @default(true)
  startDate   DateTime  @db.Date
  endDate     DateTime? @db.Date
  createdAt   DateTime  @default(now()) @db.Timestamptz()
  createdById String?

  employee Employee @relation(fields: [employeeId, tenantId], references: [id, tenantId], onDelete: Cascade)
  campus   Campus   @relation(fields: [campusId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@id([employeeId, campusId, tenantId])
  @@index([tenantId])
  @@index([campusId, tenantId])
}

// ── ClassSection ─────────────────────────────────────────────
// A class within a Program for a given AcademicYear at a given Campus.
// walasEmployeeId is single-col FK SET NULL (column FK, not join table —
// composite reserved for join tables per §6.4). Tenant alignment enforced
// app-layer via ClassSection.tenantId denorm.
// `version Int` shipped now ahead of `17_version_triggers` migration per §4.4.

model ClassSection {
  id              String    @id @default(cuid())
  tenantId        String
  programId       String
  academicYearId  String
  campusId        String
  walasEmployeeId String?
  code            String    @db.VarChar(50)
  name            String    @db.VarChar(255)
  displayOrder    Int       @default(0)
  capacity        Int?
  version         Int       @default(0)
  createdAt       DateTime  @default(now()) @db.Timestamptz()
  createdById     String?
  updatedAt       DateTime  @updatedAt @db.Timestamptz()
  updatedById     String?
  deletedAt       DateTime? @db.Timestamptz()
  deletedById     String?

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  program          Program           @relation(fields: [programId, tenantId], references: [id, tenantId], onDelete: Restrict)
  academicYear     AcademicYear      @relation(fields: [academicYearId, tenantId], references: [id, tenantId], onDelete: Restrict)
  campus           Campus            @relation(fields: [campusId, tenantId], references: [id, tenantId], onDelete: Restrict)
  walas            Employee?         @relation("ClassSectionWalas", fields: [walasEmployeeId], references: [id], onDelete: SetNull)
  teachingDefaults TeachingDefault[]
  sentraRotations  SentraRotation[]
  classSessions    ClassSession[]

  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([tenantId, programId])
  @@index([tenantId, academicYearId])
  @@index([tenantId, campusId])
  @@index([walasEmployeeId])
}

// ── Sentra ───────────────────────────────────────────────────
// Catalog table per spec §4.3 (PAUD learning-center category — Persiapan,
// Balok, Bahan Alam, Main Peran, Seni, Imtaq, Memasak, Olah Tubuh).
// SYSTEM-seeded; admin can extend in v1.1+.

model Sentra {
  id           String        @id @default(cuid())
  tenantId     String
  code         String        @db.VarChar(50)
  name         String        @db.VarChar(255)
  source       CatalogSource @default(SYSTEM)
  displayOrder Int           @default(0)
  createdAt    DateTime      @default(now()) @db.Timestamptz()
  createdById  String?
  updatedAt    DateTime      @updatedAt @db.Timestamptz()
  updatedById  String?
  deletedAt    DateTime?     @db.Timestamptz()
  deletedById  String?

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  teachingDefaults TeachingDefault[]
  sentraRotations  SentraRotation[]
  classSessions    ClassSession[]

  @@unique([id, tenantId])
  @@index([tenantId])
}

// ── TeachingDefault ──────────────────────────────────────────
// Composite-FK join per §6.4. Default sentra-teacher mapping per (class ×
// sentra × term). Overwritten per term — no soft-delete. Cascade on parent
// delete invalidates the mapping.

model TeachingDefault {
  classSectionId String
  academicTermId String
  sentraId       String
  employeeId     String
  tenantId       String
  createdAt      DateTime @default(now()) @db.Timestamptz()
  createdById    String?

  classSection ClassSection @relation(fields: [classSectionId, tenantId], references: [id, tenantId], onDelete: Cascade)
  academicTerm AcademicTerm @relation(fields: [academicTermId, tenantId], references: [id, tenantId], onDelete: Cascade)
  sentra       Sentra       @relation(fields: [sentraId, tenantId], references: [id, tenantId], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@id([classSectionId, academicTermId, sentraId, tenantId])
  @@index([tenantId])
  @@index([employeeId, tenantId])
  @@index([sentraId, tenantId])
  @@index([academicTermId, tenantId])
}

// ── SentraRotation ───────────────────────────────────────────
// Composite-FK join per §6.4. Week-grid mapping (class × dayOfWeek × term →
// sentra). dayOfWeek ISO 8601 (Mon=1 … Sun=7). No soft-delete — overwritten
// per term.

model SentraRotation {
  classSectionId String
  dayOfWeek      Int
  academicTermId String
  sentraId       String
  tenantId       String
  createdAt      DateTime @default(now()) @db.Timestamptz()
  createdById    String?

  classSection ClassSection @relation(fields: [classSectionId, tenantId], references: [id, tenantId], onDelete: Cascade)
  academicTerm AcademicTerm @relation(fields: [academicTermId, tenantId], references: [id, tenantId], onDelete: Cascade)
  sentra       Sentra       @relation(fields: [sentraId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@id([classSectionId, dayOfWeek, academicTermId, tenantId])
  @@index([tenantId])
  @@index([sentraId, tenantId])
  @@index([academicTermId, tenantId])
}

// ── ClassSession ─────────────────────────────────────────────
// One per class-day per AcademicTerm. status enum tracks operational
// lifecycle. sentraId is denorm of effective sentra (derived from
// SentraRotation but stored for query efficiency + override). No soft-delete
// (operational record). Restrict on ClassSection delete — admin must archive
// section before sessions can be removed.
// `version Int` shipped now ahead of `17_version_triggers` per §4.4.

model ClassSession {
  id             String        @id @default(cuid())
  tenantId       String
  classSectionId String
  academicTermId String
  sessionDate    DateTime      @db.Date
  dayOfWeek      Int
  sentraId       String?
  status         SessionStatus @default(PLANNED)
  startedAt      DateTime?     @db.Timestamptz()
  completedAt    DateTime?     @db.Timestamptz()
  notes          String?       @db.VarChar(2000)
  version        Int           @default(0)
  createdAt      DateTime      @default(now()) @db.Timestamptz()
  createdById    String?
  updatedAt      DateTime      @updatedAt @db.Timestamptz()
  updatedById    String?

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  classSection    ClassSection     @relation(fields: [classSectionId, tenantId], references: [id, tenantId], onDelete: Restrict)
  academicTerm    AcademicTerm     @relation(fields: [academicTermId, tenantId], references: [id, tenantId], onDelete: Restrict)
  sentra          Sentra?          @relation(fields: [sentraId], references: [id], onDelete: SetNull)
  sessionTeachers SessionTeacher[]

  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([tenantId, academicTermId])
  @@index([tenantId, sessionDate])
  @@index([tenantId, classSectionId, sessionDate])
  @@index([tenantId, status])
  @@index([sentraId, tenantId])
}

// ── SessionTeacher ───────────────────────────────────────────
// Composite-FK join per §6.4. Cascade on session/employee delete per §4.4
// "Cascade for owned children (SessionTeacher, UserRole)". role enum
// PRIMARY/SUBSTITUTE/SENTRA/ASSISTANT per spec §4.5. Single-PRIMARY-per-
// session enforced via partial unique index in 05_sessions migration
// (DSL doesn't express partial uniques).

model SessionTeacher {
  sessionId   String
  employeeId  String
  role        SessionTeacherRole
  tenantId    String
  assignedAt  DateTime           @default(now()) @db.Timestamptz()
  createdById String?

  session  ClassSession @relation(fields: [sessionId, tenantId], references: [id, tenantId], onDelete: Cascade)
  employee Employee     @relation(fields: [employeeId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@id([sessionId, employeeId, role, tenantId])
  @@index([tenantId])
  @@index([employeeId, tenantId])
}

// ════════════════════════════════════════════════════════════════════════
// Cycle p1-audit-timeline-files (foundation spec §6.1 mig 06 + 16)
// ════════════════════════════════════════════════════════════════════════

// ── AuditLog ─────────────────────────────────────────────────
// Immutable append-only log per spec §4.5. Partitioned by month from day 1
// (declarative inline `PARTITION BY RANGE ("createdAt")` in 06_audit_timeline
// migration; Prisma cannot express partitioning so the schema is a logical
// representation only — `migrate dev` would generate non-partitioned DDL,
// hence we use hand-written migrations + `migrate deploy` only).
//
// Append-only enforced by Postgres trigger `audit_log_block_update_delete()`
// (raises P0001 on UPDATE/DELETE for all roles; service-role does not bypass).
// Retention via partition-drop cron (deferred to p3+) — no per-row
// retentionUntil column.
//
// Composite PK `(id, createdAt)` required by partitioned-table semantics
// (Postgres requires the partition key in any UNIQUE / PK).
//
// `actorUserId` is non-FK by design (per Assumptions) — partition-table FK
// maintenance burden + soft-delete semantics mismatch.
//
// `before` / `after` JSONB are redacted via `lib/audit/redactor.ts` (generated
// from `/// @PII` schema annotations) before INSERT.
//
// Audit-column deviation: AuditLog has only `createdAt` + `actorUserId`
// (no updatedAt / deletedAt / *ById columns) — spec §4.4 audit-column
// convention is for *operational* entities, not the audit log itself.

model AuditLog {
  id          String      @default(cuid())
  tenantId    String
  actorUserId String?
  action      AuditAction
  resource    String      @db.VarChar(50)
  resourceId  String
  before      Json?
  after       Json?
  ipAddress   String?     @db.Inet
  userAgent   String?     @db.VarChar(500)
  createdAt   DateTime    @default(now()) @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  // Composite PK includes partition key (createdAt) — required by Postgres
  // declarative partitioning. Postgres rejects an `id`-only PK on partitioned
  // tables.
  @@id([id, createdAt])
  @@index([tenantId, createdAt])
  @@index([tenantId, resource, resourceId])
  @@index([tenantId, actorUserId, createdAt])
}

// ── TimelineEvent ────────────────────────────────────────────
// Per-subject activity feed per spec §4.1 Foundation row. Polymorphic
// (subjectKind/subjectId reference any model). `kind` is a string code from
// the timeline-event registry (`lib/timeline/events.ts` deferred to
// p1-scaffold-engine-skeleton). `payload` is Zod-validated app-side per
// registered kind.
//
// Soft-delete YES — typo correction parity with v1 buku-penghubung. AuditLog
// records SOFT_DELETE / RESTORE actions for regulatory traceability.
//
// `actorUserId` is single-col FK SET NULL (column FK not join, per §6.4 MVP
// rule that reserves composite FK for RLS-critical join tables). Tenant
// alignment via tenantId denorm + app-layer guard.

model TimelineEvent {
  id          String             @id @default(cuid())
  tenantId    String
  actorUserId String?
  subjectKind String             @db.VarChar(50)
  subjectId   String
  kind        String             @db.VarChar(50)
  visibility  TimelineVisibility @default(INTERNAL)
  payload     Json               @default("{}")
  occurredAt  DateTime           @default(now()) @db.Timestamptz()
  createdAt   DateTime           @default(now()) @db.Timestamptz()
  createdById String?
  updatedAt   DateTime           @updatedAt @db.Timestamptz()
  updatedById String?
  deletedAt   DateTime?          @db.Timestamptz()
  deletedById String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  actor  User?  @relation("TimelineEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  // GIN index on payload added in 06_audit_timeline migration (Prisma 7 lacks DSL for GIN).

  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([tenantId, subjectKind, subjectId, occurredAt])
  @@index([tenantId, actorUserId, occurredAt])
  @@index([tenantId, kind, occurredAt])
}

// ── FileAsset ────────────────────────────────────────────────
// Per spec §4.1 Foundation row. Supabase Storage metadata anchor. Storage
// path convention `<tenant-id>/<kind>/<cuid>.<ext>` documented in Ship Notes
// §16.1 runbook. Compression fields populated by sharp pipeline (deferred to
// p1-scaffold-engine-skeleton).

model FileAsset {
  id               String     @id @default(cuid())
  tenantId         String
  storagePath      String     @db.VarChar(500)
  originalName     String     @db.VarChar(255)
  mimeType         String     @db.VarChar(100)
  sizeBytes        BigInt
  kind             FileKind
  status           FileStatus @default(PENDING_UPLOAD)
  uploaderUserId   String?
  compressedAt     DateTime?  @db.Timestamptz()
  compressionRatio Decimal?   @db.Decimal(5, 2)
  createdAt        DateTime   @default(now()) @db.Timestamptz()
  createdById      String?
  updatedAt        DateTime   @updatedAt @db.Timestamptz()
  updatedById      String?
  deletedAt        DateTime?  @db.Timestamptz()
  deletedById      String?

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  uploader   User?       @relation("FileAssetUploader", fields: [uploaderUserId], references: [id], onDelete: SetNull)
  exportJobs ExportJob[] @relation("ExportJobResult")

  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, kind])
  @@index([uploaderUserId, tenantId])
}

// ── ExportJob ────────────────────────────────────────────────
// Async export tracking per spec §5.11. Inline CSV < 500 rows, async via
// pg-boss otherwise (queue setup deferred to p3+). 24h signed-URL TTL on
// resultFileAsset per §16.1.
//
// requestedByUserId is RESTRICT (operational records require attributable
// requester; admin must clean up jobs before user hard-delete — see Ship
// Notes operational caveat).

model ExportJob {
  id                String          @id @default(cuid())
  tenantId          String
  requestedByUserId String
  entityKind        String          @db.VarChar(50)
  format            ExportFormat
  status            ExportJobStatus @default(PENDING)
  filterPayload     Json            @default("{}")
  resultFileAssetId String?
  errorMessage      String?         @db.VarChar(2000)
  expiresAt         DateTime        @db.Timestamptz()
  createdAt         DateTime        @default(now()) @db.Timestamptz()
  createdById       String?
  updatedAt         DateTime        @updatedAt @db.Timestamptz()
  updatedById       String?

  tenant          Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  requestedBy     User       @relation("ExportJobRequester", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  resultFileAsset FileAsset? @relation("ExportJobResult", fields: [resultFileAssetId], references: [id], onDelete: SetNull)

  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, requestedByUserId])
  @@index([resultFileAssetId, tenantId])
}

// ── EmailLog ─────────────────────────────────────────────────
// Per spec §4.1 Foundation row. Resend SMTP delivery tracking. status is
// plain VARCHAR (not enum — operational state may grow with provider quirks
// per EmailLog precedent). messageId from Resend API response.

model EmailLog {
  id             String    @id @default(cuid())
  tenantId       String
  recipientEmail String    @db.VarChar(255)
  subject        String    @db.VarChar(500)
  template       String    @db.VarChar(100)
  status         String    @db.VarChar(50)
  messageId      String?   @db.VarChar(255)
  errorMessage   String?   @db.VarChar(2000)
  sentAt         DateTime? @db.Timestamptz()
  createdAt      DateTime  @default(now()) @db.Timestamptz()
  createdById    String?
  updatedAt      DateTime  @updatedAt @db.Timestamptz()
  updatedById    String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, recipientEmail])
}

// ── WebhookEvent ─────────────────────────────────────────────
// Per spec §4.1 Foundation row. External integration log (Xendit, Resend,
// Supabase). idempotencyKey + (source) deduplicates replays. signature is
// provider-supplied HMAC for replay verification (handler signs raw body).

model WebhookEvent {
  id             String    @id @default(cuid())
  tenantId       String
  source         String    @db.VarChar(50)
  eventType      String    @db.VarChar(100)
  payload        Json
  signature      String?   @db.VarChar(255)
  idempotencyKey String    @db.VarChar(255)
  processedAt    DateTime? @db.Timestamptz()
  errorMessage   String?   @db.VarChar(2000)
  createdAt      DateTime  @default(now()) @db.Timestamptz()
  updatedAt      DateTime  @updatedAt @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([tenantId, source, idempotencyKey])
  @@index([tenantId])
  @@index([tenantId, source, eventType])
  @@index([tenantId, processedAt])
}

// ── OrgConfig ────────────────────────────────────────────────
// Per spec §4.1 Foundation row. Singleton-per-tenant via column-level UNIQUE
// on tenantId (cleaner than @@unique([tenantId]) for the test parser; same
// effect; documented drift in Ship Notes — `migrate dev --create-only` would
// emit a separate `CREATE UNIQUE INDEX`).
//
// lemburCompliant per v1 ADR (overtime compliance toggle for payroll).
// autoDropAdmissionDays drives §7.1 admission AUTO_DROPPED cron threshold.

model OrgConfig {
  id                    String    @id @default(cuid())
  tenantId              String    @unique
  lemburCompliant       Boolean   @default(false)
  nisPrefix             String?   @db.VarChar(10)
  currentAcademicYearId String?
  autoDropAdmissionDays Int       @default(30)
  timezone              String    @default("Asia/Jakarta") @db.VarChar(50)
  locale                String    @default("id-ID") @db.VarChar(10)
  createdAt             DateTime  @default(now()) @db.Timestamptz()
  createdById           String?
  updatedAt             DateTime  @updatedAt @db.Timestamptz()
  updatedById           String?
  deletedAt             DateTime? @db.Timestamptz()
  deletedById           String?

  tenant              Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  currentAcademicYear AcademicYear? @relation("OrgConfigCurrentYear", fields: [currentAcademicYearId], references: [id], onDelete: SetNull)

  // Composite unique for any future FK target (none in MVP).
  @@unique([id, tenantId])
}

// ── Holiday ──────────────────────────────────────────────────
// Per spec §4.1 Foundation row. Tenant-scoped calendar reference. kind is
// plain VARCHAR (not enum) — small finite set may extend per locale (e.g.
// PAUD-specific). Partial unique on (tenantId, date) WHERE deletedAt IS NULL
// added in 16_scaffold migration (Prisma 7 lacks DSL for partial uniques).

model Holiday {
  id          String    @id @default(cuid())
  tenantId    String
  date        DateTime  @db.Date
  name        String    @db.VarChar(255)
  kind        String    @db.VarChar(20)
  createdAt   DateTime  @default(now()) @db.Timestamptz()
  createdById String?
  updatedAt   DateTime  @updatedAt @db.Timestamptz()
  updatedById String?
  deletedAt   DateTime? @db.Timestamptz()
  deletedById String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, date])
}

// ════════════════════════════════════════════════════════════════════════
// Cycle p2-students-guardians-household (foundation spec §6.1 mig 07)
// ════════════════════════════════════════════════════════════════════════

// ── Household ────────────────────────────────────────────────
// Per spec §6.1. Tenant-scoped, soft-delete, audit per §4.4. `code` is the
// display code (e.g. "HH-2026-001"); allocated lazily by admin tools, NULL
// until issued. Partial unique on (tenantId, code) WHERE deletedAt IS NULL
// AND code IS NOT NULL lives in 07_students migration (Prisma 7 lacks DSL
// for partial uniques). Address FK wired in p2-addresses-idn-chain — SPLIT-VIEW
// per scaffold.md §6 (Prisma single-column + DB composite SET NULL column-list).

model Household {
  id          String    @id @default(cuid())
  tenantId    String
  code        String?   @db.VarChar(50)
  addressId   String?
  notes       String?   @db.VarChar(2000)
  createdAt   DateTime  @default(now()) @db.Timestamptz()
  createdById String?
  updatedAt   DateTime  @updatedAt @db.Timestamptz()
  updatedById String?
  deletedAt   DateTime? @db.Timestamptz()
  deletedById String?

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  // SINGLE-column relation per scaffold.md §6 split-view pattern (NOT composite).
  // Mirrors Guardian.userId precedent (cycle p2-guardians T2 step 3). The DB-
  // level composite FK with column-list `SET NULL ("addressId")` lives in this
  // migration's SQL — the §6.4 tenant alignment is preserved at the DB layer.
  // `prisma migrate dev` WILL detect drift between this single-column relation
  // and the DB composite FK; REJECT regeneration in PR review.
  address  Address?  @relation(fields: [addressId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  students Student[]

  // Composite unique on (id, tenantId) — required as FK target for Student
  // composite-FK chain (§6.4) + future p2-guardians + p2-admission-funnel.
  @@unique([id, tenantId])
  // Code uniqueness is partial-WHERE (deletedAt IS NULL AND code IS NOT NULL)
  // and lives ONLY in the 07_students migration — declaring `@@unique([tenantId,
  // code])` here would cause `prisma migrate dev` to regenerate a full unique
  // constraint conflicting with the partial index. Use `findFirst` for
  // (tenantId, code) lookups; the index below covers the query.
  @@index([tenantId])
  @@index([tenantId, code])
}

// ── Student ──────────────────────────────────────────────────
// Per spec §6.1. Tenant-scoped, soft-delete, audit per §4.4. `nis` allocated
// lazily by NIS allocator (T3); unique per tenant among non-deleted rows
// (partial unique enforced in migration). `nik` is Indonesian national ID,
// PII per §4.5 — annotated `/// @PII redact` (audit redactor strips it from
// before/after payloads). `gender` uses a CHECK constraint in SQL (no enum)
// for schema-light single-binary-value field. GIN trigram index on fullName
// lives in migration only (Prisma 7 lacks DSL for GIN).

model Student {
  id          String    @id @default(cuid())
  tenantId    String
  householdId String
  programId   String
  nis         String?   @db.VarChar(50)
  nik         String?   @db.VarChar(16) /// @PII redact
  fullName    String    @db.VarChar(255)
  nickname    String?   @db.VarChar(100)
  birthPlace  String?   @db.VarChar(100)
  birthDate   DateTime? @db.Date
  // gender CHECK ('MALE', 'FEMALE') enforced at DB level via 07_students migration.
  gender      String    @db.VarChar(10)
  enrolledAt  DateTime? @db.Date
  createdAt   DateTime  @default(now()) @db.Timestamptz()
  createdById String?
  updatedAt   DateTime  @updatedAt @db.Timestamptz()
  updatedById String?
  deletedAt   DateTime? @db.Timestamptz()
  deletedById String?

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  household           Household            @relation(fields: [householdId, tenantId], references: [id, tenantId], onDelete: Restrict)
  program             Program              @relation(fields: [programId, tenantId], references: [id, tenantId], onDelete: Restrict)
  identifiers         StudentIdentifier[]
  studentGuardians    StudentGuardian[]
  guardianInvitations GuardianInvitation[]

  // Composite unique on (id, tenantId) — required as FK target for
  // StudentIdentifier composite-FK chain (§6.4) + future p2-guardians.
  @@unique([id, tenantId])
  // NIS uniqueness is partial-WHERE (deletedAt IS NULL AND nis IS NOT NULL)
  // and lives ONLY in the 07_students migration — declaring `@@unique([tenantId,
  // nis])` here would cause `prisma migrate dev` to regenerate a full unique
  // constraint conflicting with the partial index. Use `findFirst` for
  // (tenantId, nis) lookups; the index below covers the query.
  @@index([tenantId])
  @@index([tenantId, nis])
  @@index([tenantId, householdId])
  @@index([tenantId, programId])
  // Plain B-tree index for fullName equality / prefix; trigram GIN index
  // for fuzzy search lives in 07_students migration only (Prisma 7 lacks DSL).
  @@index([tenantId, fullName])
}

// ── StudentIdentifier ────────────────────────────────────────
// Per spec §6.1 + §4.5 NIS history. Tenant-scoped, soft-delete (NIS history
// retained), audit per §4.4. `kind` uses CHECK ('NIS', 'NISN', 'PREVIOUS_SCHOOL')
// at DB level — schema-light, no enum. Composite FK to Student per §6.4 with
// CASCADE on Student hard-delete (admin-tool path); soft-delete on Student
// preserves identifier history (deletedAt cascades via app-layer, not FK).
// Partial-unique single-PRIMARY-per-student guard lives in 07_students migration:
// `WHERE "isPrimary" = true AND "deletedAt" IS NULL` — diverges from
// SessionTeacher precedent because soft-deleted primaries must NOT block
// re-issue (per spec §4.5).

model StudentIdentifier {
  id          String    @id @default(cuid())
  tenantId    String
  studentId   String
  // kind CHECK ('NIS', 'NISN', 'PREVIOUS_SCHOOL') enforced at DB level.
  kind        String    @db.VarChar(30)
  value       String    @db.VarChar(100)
  isPrimary   Boolean   @default(false)
  issuedAt    DateTime? @db.Date
  notes       String?   @db.VarChar(2000)
  createdAt   DateTime  @default(now()) @db.Timestamptz()
  createdById String?
  updatedAt   DateTime  @updatedAt @db.Timestamptz()
  updatedById String?
  deletedAt   DateTime? @db.Timestamptz()
  deletedById String?

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  student Student @relation(fields: [studentId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([tenantId, studentId])
  @@index([tenantId, kind, value])
}

// ── StudentIdentifierSequence ────────────────────────────────
// Per spec §6.1 + §6.6. Operational counter row per (tenant, year, program)
// triple — NO soft-delete (append-only; matches ExportJob/EmailLog precedent
// in 16_scaffold). NIS allocator (T3) bumps `lastValue` inside a
// `pg_advisory_xact_lock` transaction — per-row contention is rare (different
// programs allocate different ranges), so lock granularity at (tenant, year)
// is sufficient. Audit-column deviation: no deletedAt / deletedById per the
// operational-record convention.

model StudentIdentifierSequence {
  id             String   @id @default(cuid())
  tenantId       String
  academicYearId String
  programId      String
  lastValue      Int      @default(0)
  createdAt      DateTime @default(now()) @db.Timestamptz()
  createdById    String?
  updatedAt      DateTime @updatedAt @db.Timestamptz()
  updatedById    String?

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  academicYear AcademicYear @relation(fields: [academicYearId, tenantId], references: [id, tenantId], onDelete: Restrict)
  program      Program      @relation(fields: [programId, tenantId], references: [id, tenantId], onDelete: Restrict)

  @@unique([tenantId, academicYearId, programId])
}

// ── Guardian ─────────────────────────────────────────────────
// Per spec §6.1 (migration 08). Tenant-scoped, soft-delete, audit per §4.4.
// `nik` Indonesian national ID — PII per §4.5 (annotated `/// @PII redact`,
// audit redactor strips it from before/after payloads). `phone` PII
// (`/// @PII mask:last4` — audit redactor masks all but last 4 chars).
//
// `userId` is the optional link to a User row created at GuardianInvitation
// acceptance (NULL until accepted, populated atomically in the consume tx).
//
// FK shape (cycle assumption 5 — split-view):
//   - DB / migration:   composite FK `(userId, tenantId) → User(id, tenantId)
//                       ON DELETE SET NULL ("userId")` (Postgres 15.4+
//                       column-list SET NULL — preserves §6.4 tenant
//                       alignment; tenantId stays bound to Guardian when
//                       a User is hard-deleted).
//   - Prisma schema:    SINGLE-column relation `user User?
//                       @relation(fields: [userId], references: [id],
//                       onDelete: SetNull)`. NOT composite. Dodges Prisma
//                       issue #25061 — composite SetNull would null all
//                       composite columns including tenantId via the
//                       Prisma client disconnect path, breaking the NOT
//                       NULL constraint at runtime.
//   - `prisma migrate dev` will detect drift and propose regeneration.
//                       REJECT in PR review — drift is intentional;
//                       `migrate deploy` (production path) only applies
//                       committed migrations and is unaffected.

model Guardian {
  id          String    @id @default(cuid())
  tenantId    String
  userId      String?
  fullName    String    @db.VarChar(255)
  email       String?   @db.VarChar(255)
  nik         String?   @db.VarChar(16) /// @PII redact
  phone       String?   @db.VarChar(20) /// @PII mask:last4
  createdAt   DateTime  @default(now()) @db.Timestamptz()
  createdById String?
  updatedAt   DateTime  @updatedAt @db.Timestamptz()
  updatedById String?
  deletedAt   DateTime? @db.Timestamptz()
  deletedById String?

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  // Single-column FK by design — see header note above. DB enforces
  // composite (userId, tenantId) → User(id, tenantId) with column-list
  // SET NULL ("userId") via the migration. Do NOT change to a composite
  // relation here without first re-confirming Prisma issue #25061 status.
  user                User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  studentGuardians    StudentGuardian[]
  guardianInvitations GuardianInvitation[]

  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([userId])
  @@index([tenantId, userId])
  @@index([tenantId, fullName])
}

// ── StudentGuardian ──────────────────────────────────────────
// Per spec §6.1 (migration 08) — many-to-many between Student and Guardian
// with relationship enum + isPrimary flag. Tenant-scoped, soft-delete, audit
// per §4.4. `relationship` uses CHECK ('FATHER', 'MOTHER', 'GUARDIAN',
// 'OTHER') at DB level — schema-light, no Prisma enum (mirrors
// Student.gender / StudentIdentifier.kind precedent in migration 07).
//
// Partial-unique PRIMARY guard (cycle assumption 8) lives ONLY in
// 08_guardians migration — scope `(studentId, tenantId, relationship)` +
// `WHERE "isPrimary" = true AND "deletedAt" IS NULL`. Permits PRIMARY
// FATHER + PRIMARY MOTHER coexisting per Indonesian PAUD admission practice.
// Do NOT declare `@@unique([studentId, tenantId, relationship])` here —
// `prisma migrate dev` would regenerate a full unique constraint
// conflicting with the partial-WHERE index (per p2-cycle-1 lesson). Use
// `findFirst` for the (studentId, tenantId, relationship) PRIMARY lookup;
// the `@@index([tenantId, studentId])` covers the query.

model StudentGuardian {
  id           String    @id @default(cuid())
  tenantId     String
  studentId    String
  guardianId   String
  // relationship CHECK ('FATHER', 'MOTHER', 'GUARDIAN', 'OTHER') at DB level.
  relationship String    @db.VarChar(20)
  isPrimary    Boolean   @default(false)
  notes        String?   @db.VarChar(2000)
  createdAt    DateTime  @default(now()) @db.Timestamptz()
  createdById  String?
  updatedAt    DateTime  @updatedAt @db.Timestamptz()
  updatedById  String?
  deletedAt    DateTime? @db.Timestamptz()
  deletedById  String?

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  student  Student  @relation(fields: [studentId, tenantId], references: [id, tenantId], onDelete: Cascade)
  guardian Guardian @relation(fields: [guardianId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([guardianId])
  @@index([tenantId, studentId])
  @@index([tenantId, guardianId])
}

// ── GuardianInvitation ───────────────────────────────────────
// Per spec §6.1 (migration 08). Token-based parent-portal activation row.
// Tenant-scoped. NO soft-delete (operational; status enum carries lifecycle;
// matches ExportJob/EmailLog precedent in 16_scaffold and
// StudentIdentifierSequence in 07_students). Audit columns:
// createdAt / createdById / updatedAt / updatedById. NO deletedAt /
// deletedById per the operational-record convention.
//
// `token` is a 32-byte base64url string (256 bits entropy, ~43 chars
// URL-safe), app-generated via `crypto.randomBytes(32).toString('base64url')`.
// NOT pgcrypto-generated — column has no DEFAULT. Stored as VARCHAR(64)
// with global UNIQUE — collision astronomically unlikely; global unique
// simplifies the consume route (token → invitation row across all tenants,
// then app-layer-gate on tenantId).
//
// `status` uses CHECK ('PENDING', 'ACCEPTED', 'EXPIRED', 'REVOKED') at DB
// level. Single-use semantics enforced via atomic
// `UPDATE ... WHERE status='PENDING'` at consume (cycle assumption 4) —
// no row-lock needed under MVCC. `expiresAt` enforced app-layer at consume
// (cycle assumption 3); pg-boss sweep PENDING+expired → EXPIRED deferred
// to p3+.
//
// `guardianId` NOT NULL (cycle assumption 6) — admin pre-creates the
// Guardian row (with userId = NULL) at invitation issue time, then issues
// the invitation referencing that Guardian. Acceptance flow populates
// Guardian.userId atomically.

model GuardianInvitation {
  id          String    @id @default(cuid())
  tenantId    String
  studentId   String
  guardianId  String
  token       String    @db.VarChar(64)
  // status CHECK ('PENDING', 'ACCEPTED', 'EXPIRED', 'REVOKED') at DB level.
  status      String    @default("PENDING") @db.VarChar(20)
  expiresAt   DateTime  @db.Timestamptz()
  acceptedAt  DateTime? @db.Timestamptz()
  createdAt   DateTime  @default(now()) @db.Timestamptz()
  createdById String?
  updatedAt   DateTime  @updatedAt @db.Timestamptz()
  updatedById String?

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  student  Student  @relation(fields: [studentId, tenantId], references: [id, tenantId], onDelete: Cascade)
  guardian Guardian @relation(fields: [guardianId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@unique([id, tenantId])
  @@unique([token])
  @@index([tenantId])
  @@index([guardianId])
  @@index([tenantId, studentId])
  @@index([tenantId, guardianId])
  @@index([tenantId, status])
}
