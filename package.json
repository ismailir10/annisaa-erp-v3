{
  "name": "school-erp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npx prisma generate && next build",
    "build:analyze": "ANALYZE=true npx prisma generate && next build",
    "vercel-build": "bash scripts/vercel-build.sh",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "npx prisma generate && tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "reseed:staging": "tsx --env-file-if-exists=.env.staging scripts/reseed-staging.ts",
    "backfill:hierarchy": "tsx --env-file-if-exists=.env.local scripts/backfill-hierarchy.ts"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.6.0",
    "@react-pdf/renderer": "^4.5.1",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.105.4",
    "@tanstack/react-table": "^8.21.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.38.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.7.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "react": "19.2.6",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.6",
    "react-resizable-panels": "^4.9.0",
    "recharts": "^3.8.0",
    "resend": "6.10.x",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.6",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^6",
    "vitest": "^4.1.3"
  }
