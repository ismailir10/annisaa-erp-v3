# Environment Variables
# Copy this file to .env.local and fill in your values

# Bundle Analyzer
# Set to "true" to enable bundle analysis during build
# ANALYZE=true

# Database (Supabase)
# DATABASE_URL="postgresql://..."
# DIRECT_URL="postgresql://..."

# Supabase
# NEXT_PUBLIC_SUPABASE_URL="https://..."
# NEXT_PUBLIC_SUPABASE_ANON_KEY="..."

# Xendit Payment Gateway
# XENDIT_SECRET_API_KEY="..."
# NEXT_PUBLIC_XENDIT_PUBLIC_API_KEY="..."
# XENDIT_WEBHOOK_TOKEN="..."

# Resend Email Service
# RESEND_API_KEY="re_..."
# RESEND_FROM_EMAIL="Talib by An Nisaa' <noreply@annisaasekolahku.com>"

# App Configuration
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Seed / Reseed
# Email of the SUPER_ADMIN owner seeded by prisma/seed.ts and scripts/reseed-staging.ts.
# Default "owner@example.test" keeps demo + E2E flows green without configuration.
# Set this on staging/prod environments to the real owner email used for Google SSO.
# OWNER_EMAIL="owner@example.test"
