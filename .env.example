# Database
# Local dev uses SQLite automatically (no config needed)
# Production: set these to Supabase pooler URLs
# DATABASE_URL=postgresql://postgres.xxx:password@aws-1-region.pooler.supabase.com:6543/postgres
# DIRECT_URL=postgresql://postgres.xxx:password@aws-1-region.pooler.supabase.com:5432/postgres

# Supabase Auth
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (for email delivery)
# RESEND_API_KEY=re_xxxxx

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin allow-list (comma-separated emails that can auto-create as SCHOOL_ADMIN)
# Users not in this list AND not matching an employee will be denied access
ADMIN_EMAILS=ismailir10@gmail.com

# Staging: override all email recipients to this address
# STAGING_EMAIL_OVERRIDE=your-test-email@gmail.com
